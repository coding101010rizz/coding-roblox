-- Prefer the server-marked canonical instances. Old PlotServer copies can
-- leave duplicate remotes/folders with identical names; WaitForChild alone may
-- bind this client to the wrong one, breaking the GUI, shop and structure select.
S.findCanonical = function(parent, name, className)
	local fallback = nil
	for _ = 1, 100 do
		for _, child in ipairs(parent:GetChildren()) do
			if child.Name == name and child.ClassName == className then
				fallback = fallback or child
				if child:GetAttribute("BuildSystemCanonical") == true then
					return child
				end
			end
		end
		task.wait(0.05)
	end
	return fallback or parent:WaitForChild(name, 10)
end

