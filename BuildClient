	dragStart = nil
	if not commitTransform() then restoreSnapshot() end
end)

local rotStart = nil
U.arcHandles.MouseButton1Down:Connect(function()
	handleGrab = true
	if groupHandles then
		groupHandleStart = {}
		for model in pairs(boxSelection) do
