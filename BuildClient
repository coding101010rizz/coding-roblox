	--------------------------------------------------------------------
	local Lighting = game:GetService("Lighting")
	local timeOverride = nil -- nil = live server time

	local applyingTime = false
	local function applyTimeOverride()
		if timeOverride == nil or applyingTime then return end
		applyingTime = true
		-- ClockTime right now holds the freshly-replicated REAL server time -
		-- stash it for the clock UI, THEN apply our local visual override
		player:SetAttribute("BuildRealTime", Lighting.ClockTime)
		player:SetAttribute("BuildTimePreview", true)
		Lighting.ClockTime = timeOverride
		applyingTime = false
	end
	Lighting:GetPropertyChangedSignal("ClockTime"):Connect(applyTimeOverride)

	U.timeBar = Instance.new("Frame")
