-- Assemble a roof as a Model (transparent when used as a ghost)
local function buildRoofModel(shape, sx, sz, rise, isGhost)
	if not RoofShapes then return nil end
	local model = Instance.new("Model")
	model.Name = "RoofPreview"
	local pieces = RoofShapes.Build(shape, Vector3.new(0, 0, 0), sx, sz, rise)
	for _, piece in ipairs(pieces) do
		local p = Instance.new(piece.wedge and "WedgePart" or "Part")
		p.Size = piece.size
		p.CFrame = piece.cf
		p.Anchored = true
		p.CanCollide = false
		p.CanQuery = false
		p.Material = isGhost and Enum.Material.ForceField or Enum.Material.SmoothPlastic
		p.Color = isGhost and Color3.fromRGB(55, 174, 255) or Color3.fromRGB(226, 228, 233)
		p.Transparency = isGhost and 0.62 or 0
		p.Parent = model
	end
	if #model:GetChildren() == 0 then model:Destroy() return nil end
	model.PrimaryPart = model:FindFirstChildWhichIsA("BasePart")
	if isGhost then
		local outline = Instance.new("Highlight")
		outline.Name = "RoofPreviewOutline"
		outline.Adornee = model
		outline.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		outline.FillTransparency = 1
		outline.OutlineTransparency = 0.08
		outline.OutlineColor = Color3.fromRGB(220, 245, 255)
		outline.Parent = model
	end
	return model
end
