local function mouseHit()
	U.rayParams.FilterDescendantsInstances = { ghost, structPreview, player.Character }
	local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
	return workspace:Raycast(unitRay.Origin, unitRay.Direction * 400, U.rayParams)
end

local function climbToPlaced(inst)
	local node = inst
	while node and node ~= workspace do
		if node:IsA("Model") then
			local parent = node.Parent
			if (parent and parent.Parent == itemsRoot)
				or node:GetAttribute("PlotIndex") ~= nil
				or node:GetAttribute("StructureKind") ~= nil then
				return node
			end
		end
		node = node.Parent
	end
	return nil
end

U.placedRay = RaycastParams.new()
U.placedRay.FilterType = Enum.RaycastFilterType.Include

-- Model + the exact raycast hit (part, position, normal) when available
local function placedHit()
	if not itemsRoot then return nil, nil end
	U.placedRay.FilterDescendantsInstances = { itemsRoot }
	local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
	local origin = unitRay.Origin
	-- step through fully-invisible helper parts so selection lands on visible geometry
	for _ = 1, 5 do
		local hit = workspace:Raycast(origin, unitRay.Direction * 400, U.placedRay)
		if not hit then break end
		if hit.Instance.Transparency < 0.95 then
			local model = climbToPlaced(hit.Instance)
			if model then return model, hit end
			break
		end
		origin = hit.Position + unitRay.Direction * 0.1
	end
	return nil, nil
end

local function placedModelUnderMouse()
	if not itemsRoot then return nil end
	-- normal cursor hit first
	if mouse.Target then
		local m = climbToPlaced(mouse.Target)
		if m then return m end
	end
	-- fallback: ray against placed items ONLY (catches thin props,
	-- foliage, and anything the cursor test misses)
	U.placedRay.FilterDescendantsInstances = { itemsRoot }
	local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
	local hit = workspace:Raycast(unitRay.Origin, unitRay.Direction * 400, U.placedRay)
	if hit then
		return climbToPlaced(hit.Instance)
	end
	return nil
end

local function makeGhost(itemName, source)
	local template = findTemplate(itemName)
	if not template then flash("Item not found!") return end
	if not ensurePrimaryPart(template) then flash("Item has no parts!") return end
	setMode("ghost")
	selectedItem = itemName
	selectedSource = source or "catalog"
	ghostRotation = 0
	ghost = template:Clone()
	ensurePrimaryPart(ghost)
	for _, part in ipairs(ghost:GetDescendants()) do
		if part:IsA("BasePart") then
			part.Transparency = math.max(part.Transparency, 0.5)
			part.CanCollide = false; part.CanQuery = false; part.Anchored = true
		end
	end
	-- compute geometry BEFORE the ghost becomes visible to the update
	-- loop (running one frame early with stale values could error and
	-- permanently kill the loop)
	local bboxCF, bboxSize = ghost:GetBoundingBox()
	local pivot = ghost:GetPivot()
	ghostBottomDelta = pivot.Position.Y - (bboxCF.Position.Y - bboxSize.Y / 2)
	ghostBoxOffset = pivot:ToObjectSpace(bboxCF)
	ghostBoxSize = bboxSize
	ghostWallKind = nil
	do
		local attr = findTemplate(itemName) and findTemplate(itemName):GetAttribute("WallItem")
		if attr == "door" or attr == "window" then
			ghostWallKind = attr
		else
			local t = findTemplate(itemName)
			local parent = t and t.Parent
			if parent and parent:IsA("Folder") then
				local n = parent.Name:lower()
				if n == "doors" then ghostWallKind = "door" end
				if n == "windows" then ghostWallKind = "window" end
			end
		end
	end
	ghostHighlight = Instance.new("Highlight")
	ghostHighlight.FillTransparency = 0.7
	ghostHighlight.Parent = ghost
