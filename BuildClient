	end)


	--------------------------------------------------------------------
	-- RESPONSIVE LAYOUT: keeps the dock (and the floating bars) on screen
	-- on laptops, small windows and phones instead of spilling off the edge
	--------------------------------------------------------------------
	local function layout()
		local vp = camera.ViewportSize
		-- v9.2: RESOLUTION-INDEPENDENT sizing. Devices report viewport units
		-- inconsistently, so instead of guessing "is this a phone?" with a
		-- pixel threshold (which silently failed on iPhones), the dock is
		-- simply never allowed to exceed ~42% of the screen's height.
		local touch = UserInputService.TouchEnabled
		local compact = touch or vp.X < 1150
		local tileH = compact and 44 or 52
		local gap = 6
		local margin = 10

		-- ONE shared width budget for ALL 12 buttons, computed FORWARD from
		-- the left. The old version anchored actions from the right, which
		-- made Shop/Clear land on top of the Sell tool on narrow screens.
		local actions = { U.shopAction, U.bulldozeAction, U.undoAction, U.copyAction, U.delAction }
		local slots = #U.toolDefs + #actions
		local budget = vp.X - 16 - margin * 2 - 12 - gap * (slots - 1)
		local tileW = math.clamp(math.floor(budget / slots), 44, compact and 64 or 84)
		local width = margin * 2 + 12 + slots * tileW + gap * (slots - 1)
		width = math.min(width, vp.X - 16)
		local dockH = compact and 302 or 334 -- larger, readable furniture previews

		-- Phones: ONE UIScale shrinks the whole dock about its bottom-center
		-- anchor - a single property write, batched by the engine into one
		-- layout pass, instead of resizing dozens of children one by one.
		if not U.dockScale then
			U.dockScale = Instance.new("UIScale")
			U.dockScale.Parent = U.dock
		end
		local s = math.clamp((vp.Y * 0.42) / dockH, 0.5, 1)
		U.dockScale.Scale = s

		U.dock.Size = UDim2.fromOffset(width, dockH)

		for i, def in ipairs(U.toolDefs) do
			local b = U.toolButtons[def.id]
			if b then
				b.Size = UDim2.fromOffset(tileW, tileH)
				b.Position = UDim2.fromOffset(margin + (i - 1) * (tileW + gap), 26)
				local lb = U.toolLabels[def.id]
				if lb then
					lb.TextSize = compact and 10 or 12
					lb.Position = UDim2.fromOffset(0, tileH - 18)
				end
			end
		end

		-- Actions CONTINUE the same row after the tools (forward-computed),
		-- so overlap is geometrically impossible at any viewport width.
		local actStart = margin + #U.toolDefs * (tileW + gap) + 12
		for i, b in ipairs(actions) do
			b.Size = UDim2.fromOffset(tileW, tileH)
			b.Position = UDim2.fromOffset(actStart + (i - 1) * (tileW + gap), 26)
			for _, child in ipairs(b:GetChildren()) do
				if child:IsA("TextLabel") then
					child.TextSize = compact and 10 or 12
					child.Position = UDim2.fromOffset(0, tileH - 18)
				end
			end
		end

		-- rows below the tool strip
		U.tabRow.Position = UDim2.fromOffset(10, 26 + tileH + 8)
		U.tabRow.Size = UDim2.new(1, -20, 0, 32)
		U.cardScroll.Position = UDim2.fromOffset(10, 26 + tileH + 46)
		U.cardScroll.Size = UDim2.new(1, -20, 0, dockH - (26 + tileH + 54))

		-- floating bars sit just above the dock, never on top of it.
		-- The dock's SCALED height is what matters on phones.
		local above = math.floor(dockH * s) + 26
		S.railAbove = above

		-- Wide bars carry their own UIScale so they shrink-to-fit narrow
		-- screens instead of clipping (Scale-based sizing, rule-compliant).
		local function fitBar(bar, designWidth)
			local sc = bar:FindFirstChildOfClass("UIScale")
			if not sc then sc = Instance.new("UIScale"); sc.Parent = bar end
			sc.Scale = math.min(1, (vp.X - 24) / designWidth, s + 0.12)
		end
		fitBar(U.selBar, 700)
		fitBar(U.boxBar, 692)
		fitBar(U.roofQuickBar, 380)

		U.selBar.Position = UDim2.new(0.5, 0, 1, -above)
		U.selBar.Size = UDim2.fromOffset(684, 112)
		U.boxBar.Position = UDim2.new(0.5, 0, 1, -above)
		U.boxBar.Size = UDim2.fromOffset(676, 52)
		U.rotateBtn.Position = UDim2.new(0.5, -34, 1, -above)
		U.cancelBtn.Position = UDim2.new(0.5, 34, 1, -above)
		U.placeBtn.Position = UDim2.new(0.5, -102, 1, -above)

		-- v9.3 MOBILE SIDE PANELS: the tall right-edge panels (Wall Placement,
		-- Roof Style, level buttons, view toggles) used to sit at fixed offsets
		-- ABOVE the dock, so on short screens they clipped off the top. Each now
		-- carries a UIScale and is anchored just above the dock, scaled to fit.
		local sideScale = touch and math.clamp(s, 0.7, 0.9) or 1
		local function fitSide(panel, offX, offY)
			local sc = panel:FindFirstChildOfClass("UIScale")
			if not sc then sc = Instance.new("UIScale"); sc.Parent = panel end
			sc.Scale = sideScale
			panel.Position = UDim2.new(1, offX, 1, -(above + offY))
		end
		fitSide(U.levelFrame, -14, 0)
		fitSide(U.viewFrame, -64, touch and 96 or 140)
		fitSide(U.wallPanel, -64, 0)
		fitSide(U.shapeBtn, -64, 0)
		U.roofQuickBar.Position = UDim2.new(0.5, 0, 1, -(above + (touch and 96 or 118)))
		U.windowBar.Position = UDim2.new(0.5, 0, 1, -(above + 64))
		U.palette.Position = UDim2.new(1, -70, 1, -above)
		U.flyPad.Position = UDim2.new(0, 12, 1, -140)

		-- Trim panel: scrollable, clamped to the space above the dock, so it
		-- can never run past the top of the screen again.
		U.trimPanel.Position = UDim2.new(1, -14, 1, -above)
		U.trimPanel.Size = UDim2.fromOffset(180, math.max(160, math.min(590, vp.Y - above - 12)))

		S.layoutRightRail()
	end

	-- RIGHT-RAIL STACKING: the tall trim panel and the paint pill / camera /
	-- time controls all share the right edge. When trim opens they slide left
	-- in one batched pass; when it closes they slide back. Purely event-driven
	-- (a Visible listener), no per-frame checks.
	S.layoutRightRail = function()
		local above = S.railAbove or 328
		local shift = U.trimPanel.Visible and 202 or 0
		U.paintPill.Position = UDim2.new(1, -(14 + shift), 1, -above)
		U.flyBtn.Position = UDim2.new(1, -(14 + shift), 1, -(above + 234))
		U.flySpeedFrame.Position = UDim2.new(1, -(64 + shift), 1, -(above + 234))
		U.timeBar.Position = UDim2.new(1, -(14 + shift), 1, -(above + 288))
	end
	U.trimPanel:GetPropertyChangedSignal("Visible"):Connect(S.layoutRightRail)

	--------------------------------------------------------------------
	-- MOBILE BUILD LAYER (v9.6)
	-- A presentation branch, not a fork: same tools, remotes and state as
	-- desktop - only the layout and camera/character behaviour differ. Gated
	-- on a per-session detection flag so PC is never affected. The server
	-- contract is byte-identical, so a phone and a PC player share a plot
	-- with zero desync.
	--------------------------------------------------------------------
	do
		-- DETECTION: default to mobile when the device can touch, but expose a
		-- toggle so touch-laptops / keyboarded tablets can override. The choice
		-- lives in an attribute so it's event-driven and survives re-opening
		-- build mode without re-asking.
		local autoMobile = UserInputService.TouchEnabled
		if player:GetAttribute("BuildLayoutMobile") == nil then
			player:SetAttribute("BuildLayoutMobile", autoMobile)
		end
		local function isMobileLayout()
			return player:GetAttribute("BuildLayoutMobile") == true
		end
		S.isMobileLayout = isMobileLayout

		-- Small corner toggle to switch layouts on the fly.
		U.layoutToggle = Instance.new("TextButton")
		U.layoutToggle.Size = UDim2.fromOffset(112, 30)
		U.layoutToggle.AnchorPoint = Vector2.new(1, 0)
		U.layoutToggle.Position = UDim2.new(1, -14, 0, 62)
		U.layoutToggle.BackgroundColor3 = C.PANEL
		U.layoutToggle.Font = Enum.Font.GothamBold
		U.layoutToggle.TextSize = 11
		U.layoutToggle.TextColor3 = C.TEXT_GRAY
		U.layoutToggle.Text = isMobileLayout() and "Layout: Mobile" or "Layout: PC"
		U.layoutToggle.Visible = false
		U.layoutToggle.Parent = U.gui
		corner(U.layoutToggle, 8); stroke(U.layoutToggle)
		U.layoutToggle.MouseButton1Click:Connect(function()
			player:SetAttribute("BuildLayoutMobile", not isMobileLayout())
		end)

		--------------------------------------------------------------------
		-- CHARACTER LOCK: while building on mobile, the avatar is frozen so a
		-- finger-drag DRAWS instead of walking. This is the single biggest
		-- mobile fix. On exit / layout-switch the character is released.
		--------------------------------------------------------------------
		local locked = false
		local savedWalk, savedJump = 16, 50
		local function setCharacterLocked(on)
			local char = player.Character
			local humanoid = char and char:FindFirstChildOfClass("Humanoid")
			local root = char and char:FindFirstChild("HumanoidRootPart")
			if on == locked then return end
			locked = on
			if on then
				if humanoid then
					savedWalk = humanoid.WalkSpeed
					savedJump = humanoid.JumpPower
					humanoid.WalkSpeed = 0
					humanoid.JumpPower = 0
				end
				if root then root.Anchored = true end
			else
				if humanoid then
					humanoid.WalkSpeed = savedWalk
					humanoid.JumpPower = savedJump
				end
				if root then root.Anchored = false end
			end
		end
		S.setBuildCharacterLocked = setCharacterLocked

		--------------------------------------------------------------------
		-- BLOXBURG-STYLE ORBIT CAMERA (mobile): the camera orbits a focus
		-- point over the plot. One-finger drag on empty space orbits; pinch
		-- zooms; two-finger drag pans the focus. No D-pad. Reuses camYaw/
		-- camPitch already declared in the free-cam block above.
		--------------------------------------------------------------------
		local orbitFocus = Vector3.zero
		local orbitDist = 42
		local orbitConn = nil
		-- v9.8 CAMERA: remember the plot so we can CLAMP the focus and distance
		-- to the plot area + a margin. Without this the camera flew off into
		-- the distance (the user's "pushes you off too far").
		local orbitPlot = nil
		local ORBIT_MARGIN = 6 -- studs beyond the plot edge (small: keeps other
		-- players' plots out of view while giving a little breathing room)

		local function clampFocus()
			if not orbitPlot then return end
			local rel = orbitPlot.CFrame:PointToObjectSpace(orbitFocus)
			local hx = orbitPlot.Size.X / 2 + ORBIT_MARGIN
			local hz = orbitPlot.Size.Z / 2 + ORBIT_MARGIN
			rel = Vector3.new(
				math.clamp(rel.X, -hx, hx),
				rel.Y,
				math.clamp(rel.Z, -hz, hz))
			orbitFocus = orbitPlot.CFrame:PointToWorldSpace(rel)
		end

		local function orbitStep()
			local rot = CFrame.fromEulerAnglesYXZ(camPitch, camYaw, 0)
			local offset = rot * Vector3.new(0, 0, orbitDist)
			camera.CFrame = CFrame.lookAt(orbitFocus + offset, orbitFocus)
		end

		local function startOrbitCam()
			-- v10.1: orbit is authoritative on mobile - make sure the old
			-- free-cam (WASD/fly) loop is fully OFF, or both camera systems run
			-- at once and a single drag appears to move the camera even mid-build.
			if flying and S.forceLandRef then S.forceLandRef() end
			local plot = myPlotPart()
			orbitPlot = plot
			if plot then
				orbitFocus = plot.Position + Vector3.new(0, WALL_HEIGHT * 0.5, 0)
				orbitDist = math.clamp(plot.Size.Magnitude * 0.5, 24, 90)
			else
				orbitFocus = camera.CFrame.Position + camera.CFrame.LookVector * 20
			end
			camPitch = -0.5
			camera.CameraType = Enum.CameraType.Scriptable
			if not orbitConn then
				orbitConn = RunService.RenderStepped:Connect(orbitStep)
			end
			orbitStep()
		end
		local function stopOrbitCam()
			if orbitConn then orbitConn:Disconnect() orbitConn = nil end
			orbitPlot = nil
			camera.CameraType = Enum.CameraType.Custom
		end

		-- Pinch to zoom, two-finger PAN moves the focus, two-finger TWIST
		-- rotates the view - matching Bloxburg's mobile camera. Single-finger
		-- drag orbits via the free-cam TouchMoved handler above (gentle sens).
		UserInputService.TouchPinch:Connect(function(_, scale, _, state)
			if not (isMobileLayout() and U.dock.Visible and orbitConn) then return end
			if state == Enum.UserInputState.Change then
				-- v10: wider zoom band (8..160) and a gentler per-event step so
				-- pinch has real range instead of feeling capped. scale is the
				-- ratio of current/previous finger spread.
				local step = math.clamp(scale, 0.85, 1.15)
				orbitDist = math.clamp(orbitDist / step, 8, 160)
			end
		end)
		UserInputService.TouchRotate:Connect(function(_, rotation, _, state)
			if not (isMobileLayout() and U.dock.Visible and orbitConn) then return end
			if state == Enum.UserInputState.Change then
				-- two-finger twist spins the camera yaw, clamped per event
				camYaw -= math.clamp(math.rad(rotation) * 0.4, -0.08, 0.08)
			end
		end)
		UserInputService.TouchPan:Connect(function(_, totalTranslation, _, state)
			if not (isMobileLayout() and U.dock.Visible and orbitConn) then return end
			if state == Enum.UserInputState.Change then
				-- pan the focus in the camera's ground plane, then clamp to plot
				local rot = CFrame.fromEulerAnglesYXZ(0, camYaw, 0)
				local right = rot.RightVector
				local fwd = rot.LookVector
				-- scale pan by distance so it feels consistent when zoomed
				local k = 0.04 * (orbitDist / 42)
				orbitFocus -= (right * totalTranslation.X + fwd * -totalTranslation.Y) * k
				clampFocus()
			end
		end)

		--------------------------------------------------------------------
		-- ENGAGE / DISENGAGE the mobile layer. Driven by the same dock
		-- visibility signal everything else uses - no polling.
		--------------------------------------------------------------------
		local function applyMobileState()
			local on = isMobileLayout() and U.dock.Visible
			U.layoutToggle.Visible = U.dock.Visible and UserInputService.TouchEnabled
			U.layoutToggle.Text = isMobileLayout() and "Layout: Mobile" or "Layout: PC"
			-- hide the desktop free-cam D-pad + its button on mobile (orbit
			-- replaces it); hide the camera arrow pad entirely
			if U.flyBtn then U.flyBtn.Visible = U.dock.Visible and not isMobileLayout() end
			if U.flyPad then U.flyPad.Visible = false end
			if on then
				setCharacterLocked(true)
				startOrbitCam()
			else
				stopOrbitCam()
				setCharacterLocked(false)
			end
		end
		S.applyMobileState = applyMobileState

		U.dock:GetPropertyChangedSignal("Visible"):Connect(applyMobileState)
		player:GetAttributeChangedSignal("BuildLayoutMobile"):Connect(function()
			-- re-run layout so panel sizing switches immediately
			applyMobileState()
			layout()
		end)
		-- respawns must not leave a locked/anchored character stranded
		player.CharacterAdded:Connect(function()
			locked = false
			if isMobileLayout() and U.dock.Visible then
				task.wait(0.3)
				setCharacterLocked(true)
			end
		end)
	end

	layout()
	camera:GetPropertyChangedSignal("ViewportSize"):Connect(layout)
end

S.initializeLateBuildUI()
S.initializeLateBuildUI = nil
print("[BuildClient v10.2] GUI initialized - responsive mobile layout, two-sided walls")
