S.setWallPreviewSegment = function(part, ax, az, bx, bz, planeY)
	local a = Vector3.new(ax, 0, az)
	local b = Vector3.new(bx, 0, bz)
	local length = math.max((b - a).Magnitude, 0.05)
	local mid = (a + b) / 2 + Vector3.new(0, planeY + WALL_HEIGHT / 2, 0)
	-- v9.1: preview matches the server's corner sewing (+half thickness per end)
	part.Size = Vector3.new(0.5, WALL_HEIGHT, length + 0.5)
	part.CFrame = CFrame.lookAt(mid, Vector3.new(bx, mid.Y, bz))
	part.Transparency = 0.5
	part.Color = C.ACCENT
	return length
end

S.createPreviewPart = function(parent, name)
	local part = Instance.new("Part")
	part.Name = name
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CastShadow = false
	part.Transparency = 0.5
	part.Color = C.ACCENT
	part.Material = Enum.Material.SmoothPlastic
	part.Parent = parent
	return part
end

S.updateRoofMarkers = function(x1, z1, x2, z2, y, snappedStart, snappedEnd)
	local corners = {
		Vector3.new(x1, y, z1), Vector3.new(x2, y, z1),
		Vector3.new(x2, y, z2), Vector3.new(x1, y, z2),
	}
	local center = Vector3.new((x1 + x2) / 2, y + 0.12, (z1 + z2) / 2)

	local function getPart(index, name, shape, size, colour, transparency)
		local part = S.roofMarkers[index]
		if not part then
			part = Instance.new("Part")
			part.Name = name
			part.Anchored = true
			part.CanCollide = false
			part.CanTouch = false
			part.CanQuery = false
			part.CastShadow = false
			part.Material = Enum.Material.Neon
			part.Parent = camera
			S.roofMarkers[index] = part
		end
		part.Shape = shape
		part.Size = size
		part.Color = colour
		part.Transparency = transparency
		return part
	end

	-- Every handle is round. Green = anchored/snap start, blue = live end.
	for i, point in ipairs(corners) do
		local colour = C.ACCENT
		if i == 1 then colour = snappedStart and C.GREEN or Color3.fromRGB(86, 220, 150) end
		if i == 3 then colour = snappedEnd and C.GREEN or Color3.fromRGB(55, 174, 255) end
		local dot = getPart(i, "RoofSnapDot", Enum.PartType.Ball,
			Vector3.new(0.82, 0.82, 0.82), colour, 0.04)
		dot.Position = point
	end

	local centerDot = getPart(5, "RoofCenter", Enum.PartType.Ball,
		Vector3.new(0.62, 0.62, 0.62), Color3.fromRGB(235, 245, 255), 0.12)
	centerDot.Position = center

	local function setLine(index, a, b, colour, thickness)
		local line = getPart(index, "RoofGuide", Enum.PartType.Block,
			Vector3.new(thickness, thickness, 1), colour, 0.18)
		local delta = b - a
		local length = math.max(delta.Magnitude, 0.05)
		line.Size = Vector3.new(thickness, thickness, length)
		if delta.Magnitude < 0.001 then
			line.CFrame = CFrame.new((a + b) / 2)
		else
			line.CFrame = CFrame.lookAt((a + b) / 2, b)
		end
	end
	setLine(6, corners[1], corners[2], Color3.fromRGB(185, 232, 255), 0.11)
	setLine(7, corners[2], corners[3], Color3.fromRGB(185, 232, 255), 0.11)
	setLine(8, corners[3], corners[4], Color3.fromRGB(185, 232, 255), 0.11)
	setLine(9, corners[4], corners[1], Color3.fromRGB(185, 232, 255), 0.11)
	setLine(10, corners[1] + Vector3.new(0, 0.05, 0), corners[3] + Vector3.new(0, 0.05, 0),
		Color3.fromRGB(255, 214, 102), 0.08)

	-- A world-space label makes the dimensions and drag direction readable on
	-- mouse and touch without looking back at the toolbar.
	local label = centerDot:FindFirstChild("DirectionLabel")
	if not label then
		label = Instance.new("BillboardGui")
		label.Name = "DirectionLabel"
		label.Size = UDim2.fromOffset(190, 44)
		label.StudsOffsetWorldSpace = Vector3.new(0, 1.8, 0)
		label.AlwaysOnTop = true
		label.Parent = centerDot
		local text = Instance.new("TextLabel")
		text.Name = "Text"
		text.Size = UDim2.fromScale(1, 1)
		text.BackgroundColor3 = C.PANEL
		text.BackgroundTransparency = 0.16
		text.Font = Enum.Font.GothamBold
		text.TextSize = 14
		text.TextColor3 = C.TEXT_GRAY
		text.TextStrokeTransparency = 0.75
		text.Parent = label
		corner(text, 10)
	end
	local dx, dz = x2 - x1, z2 - z1
	local xDir = dx >= 0 and "E" or "W"
	local zDir = dz >= 0 and "S" or "N"
	local text = label:FindFirstChild("Text")
	if text then
		text.Text = string.format("%d × %d studs  •  %s / %s",
			math.floor(math.abs(dx) + 0.5), math.floor(math.abs(dz) + 0.5), xDir, zDir)
	end
end

--------------------------------------------------------------------
-- PER-FRAME (active only while a tool that needs live previews is up;
-- every branch early-outs, and hover raycasts never run on touch)
--------------------------------------------------------------------
RunService.RenderStepped:Connect(function()
	if mode == "ghost" and ghost then
		local hit = mouseHit()
		if not hit then
			S.wallAttachTarget = nil
			-- no surface under the cursor: park the ghost away and block
			-- placement (this is what caused items floating in the sky)
			ghost:PivotTo(CFrame.new(0, -10000, 0))
			colliding = true
			if ghostHighlight then
				ghostHighlight.FillColor = C.RED
				ghostHighlight.OutlineColor = C.RED
			end
		elseif ghostWallKind then
			-- door/window models: snap INTO walls, aligned to the wall
			local wallModel = climbToPlaced(hit.Instance)
			if wallModel and wallModel.Name == "__Wall" and wallModel.PrimaryPart then
				S.wallAttachTarget = wallModel
				local wallPart = wallModel.PrimaryPart
				local rel = wallPart.CFrame:PointToObjectSpace(hit.Position)
				local H = wallPart.Size.Y
				local wallBottomY = wallPart.Position.Y - H/2
				local yPos
				if ghostWallKind == "door" then
					yPos = wallBottomY + ghostBottomDelta
				else
					local maxSill = math.max(0, H - ghostBoxSize.Y)
					local sill = math.clamp(S.windowSill, 0, maxSill)
					yPos = wallBottomY + sill + ghostBottomDelta
				end
				local inPlane = wallPart.CFrame * CFrame.new(0, 0, math.round(rel.Z))
				-- must match WALL_ITEM_YAW on the server so the preview
				-- shows the true final facing
				local flip = (ghostRotation % (2 * math.pi) >= math.pi) and math.pi or 0
				ghostWallFlip = flip > 0
				local cf = CFrame.new(inPlane.Position.X, yPos, inPlane.Position.Z)
					* wallPart.CFrame.Rotation * CFrame.Angles(0, math.rad(90) + flip, 0)
				ghost:PivotTo(cf)
				colliding = false
				if ghostHighlight then
					ghostHighlight.FillColor = C.GREEN
					ghostHighlight.OutlineColor = C.GREEN
				end
			else
				S.wallAttachTarget = nil
				ghost:PivotTo(CFrame.new(0, -10000, 0))
				colliding = true
				if ghostHighlight then
					ghostHighlight.FillColor = C.RED
					ghostHighlight.OutlineColor = C.RED
				end
			end
		else
			local pos = hit.Position
			local n = hit.Normal
			local yPos
			if n.Y > 0.5 then
				yPos = pos.Y + ghostBottomDelta -- floor: sit on top
			elseif n.Y < -0.5 then
				-- ceiling-mounted furniture hangs from the underside
				yPos = pos.Y - (ghostBoxSize.Y - ghostBottomDelta)
			else
				yPos = pos.Y + ghostBottomDelta - ghostBoxSize.Y / 2 -- wall mount: center on hit
			end
			local snapped = Vector3.new(
				math.round(pos.X / GRID) * GRID,
				yPos,
				math.round(pos.Z / GRID) * GRID
			)
			if math.abs(n.Y) <= 0.5 then
				-- push off the wall face so it doesn't embed
				local r = (ghostBoxSize.X + ghostBoxSize.Z) / 4
				snapped += Vector3.new(n.X, 0, n.Z) * r
			end
			local cf = CFrame.new(snapped) * CFrame.Angles(0, ghostRotation, 0)
			ghost:PivotTo(cf)
			colliding = false
			if itemsRoot and ghostBoxOffset then
				-- furniture-vs-furniture only, and only on this player's plot.
				local furnitureOnly = {}
				local activePlot = myPlotPart()
				for _, plotFolder in ipairs(itemsRoot:GetChildren()) do
					for _, m in ipairs(plotFolder:GetChildren()) do
						if m:IsA("Model") and not S.isStructure(m)
							and plotOfModel(m) == activePlot then
							table.insert(furnitureOnly, m)
						end
					end
				end
				if #furnitureOnly > 0 then
					U.overlapParams.FilterDescendantsInstances = furnitureOnly
					colliding = #workspace:GetPartBoundsInBox(cf * ghostBoxOffset, ghostBoxSize * 0.85, U.overlapParams) > 0
				end
			end
			if ghostHighlight then
				ghostHighlight.FillColor = colliding and C.RED or C.GREEN
				ghostHighlight.OutlineColor = colliding and C.RED or C.GREEN
			end
		end
	elseif UserInputService.TouchEnabled
		and (mode == "trim" or mode == "remove" or mode == "paint" or mode == "sell") then
		-- v9: touch has no hover. Skip the per-frame raycasts entirely on
		-- tablets/phones - tapping still selects via placedHit() in InputBegan.
		U.hoverHighlight.Parent = nil
	elseif mode == "trim" then
		U.hoverHighlight.FillColor = C.ACCENT
		U.hoverHighlight.OutlineColor = C.ACCENT
		local hovering = placedHit()
		if hovering and hovering.Name ~= "__Wall" then hovering = nil end
		U.hoverHighlight.Parent = hovering
		if hovering and hovering.PrimaryPart then
			local _, hoverHit = placedHit()
			local face = "front"
			if hoverHit then
				local toHit = hoverHit.Position - hovering.PrimaryPart.Position
				face = (toHit:Dot(hovering.PrimaryPart.CFrame.RightVector) >= 0)
					and "this side" or "far side"
			end
			U.header.Text = "TRIM  ·  " .. S.trimStyle .. "  ·  " .. face
		else
			U.header.Text = "TRIM  ·  hover the wall face you want trimmed"
		end
	elseif mode == "remove" or mode == "paint" or mode == "sell" then
		U.hoverHighlight.FillColor = (mode == "remove") and C.RED
			or ((mode == "sell") and C.GOLD or C.ACCENT)
		if mode == "sell" then
			local hovering = placedHit()
			if hovering and not S.isStructure(hovering) then
				local tmpl = findTemplate(hovering.Name)
				local p = tmpl and tmpl:GetAttribute("Price")
				local payout = (type(p) == "number") and math.floor(p * 0.5) or 0
				U.header.Text = "SELL  ·  " .. hovering.Name .. "  ·  +" .. money(payout)
			else
				U.header.Text = "SELL  ·  click an item to sell it"
			end
		end
		U.hoverHighlight.OutlineColor = U.hoverHighlight.FillColor
		local model = placedHit()
		if not model then model = placedModelUnderMouse() end
		-- paint mode highlights everything (furniture is paintable per-part)
		U.hoverHighlight.Parent = model
	elseif (mode == "wall" or mode == "floor" or mode == "roof") and not structStart then
		-- Tool armed but not dragging yet: float the guidelines at the cursor so
		-- you can line up where a wall/floor/roof will START.
		local p = planePoint()
		if p then
			local cx, cz = snapStruct(p)
			if mode == "wall" then cx, cz = S.snapWallPoint(cx, cz) end
			S.showGuidelines(cx, cz, buildPlaneY())
		else
			S.hideGuidelines()
		end
	elseif (mode == "wall" or mode == "floor" or mode == "roof") and structStart then
		local p = planePoint()
		if p and structPreview then
			local cx, cz = snapStruct(p)
			local roofEndSnapped = false
			if mode == "roof" then
				cx, cz, roofEndSnapped = S.snapRoofPoint(cx, cz)
			end
			local planeY = buildPlaneY() or structStart.Y
			S.showGuidelines(cx, cz, planeY) -- follow the moving endpoint
			if mode == "wall" then
				local dx, dz = cx - structStart.X, cz - structStart.Z
				if S.wallMode == "line" then
					-- Lock line walls to the nearest axis or exact 45-degree diagonal.
					local adx, adz = math.abs(dx), math.abs(dz)
					if math.abs(adx - adz) <= WGRID then
						local d = math.max(adx, adz)
						cx = structStart.X + (dx >= 0 and d or -d)
						cz = structStart.Z + (dz >= 0 and d or -d)
					elseif adx > adz then
						cz = structStart.Z
					else
						cx = structStart.X
					end
					-- After the normal axis/45-degree guide, magnetize the endpoint
					-- to a nearby existing corner or one-stud T-junction.
					cx, cz = S.snapWallPoint(cx, cz)
					local length = S.setWallPreviewSegment(structPreview, structStart.X, structStart.Z, cx, cz, planeY)
					U.header.Text = "WALL  ·  " .. math.floor(length + 0.5) .. " studs"
				else
					cx, cz = S.snapWallPoint(cx, cz)
					local x1, x2 = math.min(structStart.X, cx), math.max(structStart.X, cx)
					local z1, z2 = math.min(structStart.Z, cz), math.max(structStart.Z, cz)
					local north = structPreview:FindFirstChild("North")
					local south = structPreview:FindFirstChild("South")
					local west = structPreview:FindFirstChild("West")
					local east = structPreview:FindFirstChild("East")
					S.setWallPreviewSegment(north, x1, z1, x2, z1, planeY)
					S.setWallPreviewSegment(south, x1, z2, x2, z2, planeY)
					S.setWallPreviewSegment(west, x1, z1, x1, z2, planeY)
					S.setWallPreviewSegment(east, x2, z1, x2, z2, planeY)
					local sx, sz = math.abs(x2 - x1), math.abs(z2 - z1)
					U.header.Text = "WALL BOX  ·  " .. math.floor(sx + 0.5) .. " x " .. math.floor(sz + 0.5)
				end
				S.structEndX, S.structEndZ = cx, cz
			else
				local startX, startZ, endX, endZ = structStart.X, structStart.Z, cx, cz
				if mode == "roof" then
					local ox = (cx >= structStart.X) and 1 or -1
					local oz = (cz >= structStart.Z) and 1 or -1
					local overhang = S.roofOverhang or 0
					startX -= ox * overhang
					startZ -= oz * overhang
					endX += ox * overhang
					endZ += oz * overhang
				end
				local sx = math.max(math.abs(endX - startX), 0.5)
				local sz = math.max(math.abs(endZ - startZ), 0.5)
				-- roofs cap the TOP of the level, floors sit at its base:
				-- preview at the height the server will actually build
				local midXp = (startX + endX) / 2
				local midZp = (startZ + endZ) / 2

				if mode == "roof" and roofShape ~= "flat" and RoofShapes then
					-- SHAPED ROOF: preview the real geometry, rebuilt as the
					-- footprint changes, so nothing is a surprise
					local rise = math.clamp(math.min(sx, sz) * 0.35 * roofPitch, 1, 14)
					local buildX, buildZ = sx, sz
					if S.roofRotation % 180 == 90 then buildX, buildZ = sz, sx end
					local sig = roofShape .. ":" .. math.floor(buildX) .. ":"
						.. math.floor(buildZ) .. ":" .. roofPitch .. ":" .. S.roofRotation
					if S.roofGhostSig ~= sig then
						S.roofGhostSig = sig
						if S.roofGhost then S.roofGhost:Destroy() end
						S.roofGhost = buildRoofModel(roofShape, buildX, buildZ, rise, true)
						if S.roofGhost then S.roofGhost.Parent = camera end
					end
					if S.roofGhost then
						S.roofGhost:PivotTo(CFrame.new(midXp, planeY + WALL_HEIGHT - ROOF_FLOOR_GAP, midZp)
							* CFrame.Angles(0, math.rad(S.roofRotation), 0))
					end
					S.updateRoofMarkers(startX, startZ, endX, endZ, planeY + WALL_HEIGHT + 0.35,
						S.roofStartSnapped, roofEndSnapped)
					-- Keep a translucent footprint beneath the real roof geometry so the
					-- player can see exactly which grid cells will be covered.
					structPreview.Transparency = 0.74
					structPreview.Material = Enum.Material.ForceField
					structPreview.Color = Color3.fromRGB(55, 174, 255)
					structPreview.Size = Vector3.new(sx, 0.12, sz)
					structPreview.CFrame = CFrame.new(midXp, planeY + WALL_HEIGHT + 0.06, midZp)
				else
					if S.roofGhost then S.roofGhost:Destroy() S.roofGhost = nil S.roofGhostSig = nil end
					structPreview.Transparency = 0.5
					local previewY = (mode == "roof")
						and (planeY + WALL_HEIGHT + 0.3)
						or (planeY + 0.25)
					structPreview.Size = Vector3.new(sx, (mode == "roof") and 0.6 or 0.4, sz)
					structPreview.CFrame = CFrame.new(midXp, previewY, midZp)
					if mode == "roof" then
						S.updateRoofMarkers(startX, startZ, endX, endZ, planeY + WALL_HEIGHT + 0.35,
							S.roofStartSnapped, roofEndSnapped)
					end
				end
				S.structEndX, S.structEndZ = cx, cz
				local dims = math.floor(sx + 0.5) .. " x " .. math.floor(sz + 0.5)
				U.header.Text = (mode == "roof")
					and (roofShape:upper() .. " ROOF  ·  " .. dims)
					or ("FLOOR  ·  " .. dims)
				-- same-kind overlap preview (floors vs floors, roofs vs roofs)
				local wanted = (mode == "roof") and "__Roof" or "__Floor"
				local includes = {}
				if itemsRoot then
					for _, plotFolder in ipairs(itemsRoot:GetChildren()) do
						for _, m in ipairs(plotFolder:GetChildren()) do
							if m:IsA("Model") and m.Name == wanted then
								table.insert(includes, m)
							end
						end
					end
				end
				local bad = false
				if #includes > 0 and (mode ~= "roof" or roofShape == "flat") then
					U.overlapParams.FilterDescendantsInstances = includes
					local checkSize = Vector3.new(math.max(sx - 0.4, 0.1), 2, math.max(sz - 0.4, 0.1))
					bad = #workspace:GetPartBoundsInBox(structPreview.CFrame, checkSize, U.overlapParams) > 0
				end
				structPreview.Color = bad and C.RED or C.ACCENT
			end
		end
	end
end)

