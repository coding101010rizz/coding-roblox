		dragSelPending = false
		rotStart = selModel:GetPivot()
		takeSnapshot()
	end
end)
U.arcHandles.MouseDrag:Connect(function(axis, relativeAngle)
	if groupHandles and groupHandleStart then
		local rs = rotSnap()
		local snapped = math.rad(math.round(math.deg(relativeAngle) / rs) * rs)
		local dir = Vector3.new(
			axis == Enum.Axis.X and 1 or 0,
			axis == Enum.Axis.Y and 1 or 0,
			axis == Enum.Axis.Z and 1 or 0
		)
		local turn = CFrame.fromAxisAngle(dir, snapped)
		local center = groupHandleStart.__proxy.Position
		for model, startPivot in pairs(groupHandleStart) do
			if model ~= "__proxy" and typeof(model) == "Instance" and model.Parent then
				local offset = startPivot.Position - center
				model:PivotTo(CFrame.new(center + turn * offset) * (turn * startPivot.Rotation))
			end
		end
		return
	end
	if not (selModel and rotStart) then return end
	-- rotate about whichever ring was grabbed (X/Z = vertical tilts)
	local dir = Vector3.new(
		axis == Enum.Axis.X and 1 or 0,
		axis == Enum.Axis.Y and 1 or 0,
		axis == Enum.Axis.Z and 1 or 0
	)
	local rs = rotSnap()
	local snapped = math.rad(math.round(math.deg(relativeAngle) / rs) * rs)
	selModel:PivotTo(clampToPlot(rotStart * CFrame.fromAxisAngle(dir, snapped), selModel))
	liveSync()
end)
