end)
U.resizeHandles.MouseDrag:Connect(function(face, distance)
	local part = selModel and selModel.PrimaryPart
	if not (part and sizeStart and cfStart) then return end
	local dir = Vector3.fromNormalId(face)
	local snapped = math.round(distance / moveSnap()) * moveSnap()
	local absDir = Vector3.new(math.abs(dir.X), math.abs(dir.Y), math.abs(dir.Z))
	local newSize = sizeStart + absDir * snapped
	newSize = Vector3.new(math.max(newSize.X, 0.4), math.max(newSize.Y, 0.4), math.max(newSize.Z, 0.4))
	local shift = dir * ((newSize - sizeStart):Dot(absDir)) / 2
	-- Stop growing at the plot edge (client-side; server enforces too)
	local newCF = cfStart * CFrame.new(shift)
	if selPlot then
		local rel = selPlot.CFrame:ToObjectSpace(newCF)
		local px, pz = projectedHalves(rel.Rotation, newSize)
		if math.abs(rel.Position.X) + px > selPlot.Size.X/2 + 1
			or math.abs(rel.Position.Z) + pz > selPlot.Size.Z/2 + 1 then
			return
		end
	end
	part.Size = newSize
	part.CFrame = newCF
	liveSync()
end)
