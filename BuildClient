	local misc = {}
	for _, child in ipairs(furnitureFolder:GetChildren()) do
		if child:IsA("Folder") then
			local items = {}
			for _, m in ipairs(child:GetChildren()) do
				if m:IsA("Model") then table.insert(items, m) end
			end
			if #items > 0 then table.insert(categories, { name = child.Name, items = items }) end
		elseif child:IsA("Model") then
			table.insert(misc, child)
		end
	end
	table.sort(categories, function(a, b) return a.name < b.name end)
	if #misc > 0 then table.insert(categories, { name = "Misc", items = misc }) end
end

