commitTransform = function()
	if not selModel then return true end
	local pivot = selModel:GetPivot()
	if S.isStructure(selModel) then
		local part = selModel.PrimaryPart
		if not part then return true end
		local prx, pry, prz = part.CFrame:ToOrientation()
		local ok, err = buildRemote:InvokeServer({
			action = "resize", target = selModel,
			sx = part.Size.X, sy = part.Size.Y, sz = part.Size.Z,
			x = part.Position.X, y = part.Position.Y, z = part.Position.Z,
			rot = pry, rx = prx, rz = prz,
		})
		if not ok and err then flash(tostring(err)) end
		return ok
	else
		local rxO, ryO, rzO = pivot:ToOrientation()
		local actualScale = selScale
		pcall(function() actualScale = selModel:GetScale() end)
		selScale = actualScale
		local ok, err = buildRemote:InvokeServer({
			action = "transform", target = selModel,
			x = pivot.Position.X, y = pivot.Position.Y, z = pivot.Position.Z,
			rot = ryO, rx = rxO, rz = rzO, scale = actualScale,
		})
		if not ok and err then flash(tostring(err)) end
		return ok
	end
end

local function select(model)
	if clearBoxSelectionRef then clearBoxSelectionRef() end
	deselect()
	selModel = model
	selPlot = plotOfModel(model)
	selScale = 1
	pcall(function() selScale = model:GetScale() end)
	local part = model.PrimaryPart
	if not part then ensurePrimaryPart(model) part = model.PrimaryPart end
	if not part then return end
	U.selBox.Adornee = model
	U.moveHandles.Adornee = part
	-- Structures stay upright. Furniture gets all three rotation rings so
	-- advanced placement is possible without breaking wall/floor alignment.
	U.arcHandles.Axes = S.isStructure(model)
		and Axes.new(Enum.Axis.Y)
		or Axes.new(Enum.Axis.X, Enum.Axis.Y, Enum.Axis.Z)
	U.arcHandles.Adornee = part
	U.resizeHandles.Adornee = S.isStructure(model) and part or nil
	U.scaleUp.Visible = true
	U.scaleDown.Visible = true
	U.selBar.Visible = true
end

