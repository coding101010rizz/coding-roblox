local function tryPlace()
	if not (ghost and selectedItem) then return end
	if colliding then flash("Too close to another item!") return end
	local pivot = ghost:GetPivot()
	local _, pivotYaw, _ = pivot:ToEulerAnglesYXZ()
	local ok, err = buildRemote:InvokeServer({
		action = "place", item = selectedItem, source = selectedSource,
		x = pivot.Position.X, y = pivot.Position.Y, z = pivot.Position.Z,
		rot = ghostWallKind and pivotYaw or ghostRotation,
		flip = ghostWallKind and ghostWallFlip or nil,
		wallKind = ghostWallKind, wallTarget = S.wallAttachTarget,
		sill = (ghostWallKind == "window") and S.windowSill or nil,
	})
	if not ok and err then flash(tostring(err)) end
	if ok and typeof(err) == "Instance" then
		table.insert(undoStack, err) -- second return value is the placed model
		if #undoStack > 40 then table.remove(undoStack, 1) end
		task.defer(refreshLevelView)
	end
end

undoLast = function()
	while #undoStack > 0 do
		local item = table.remove(undoStack)
		if item and item.Parent then
			local okU = buildRemote:InvokeServer({ action = "remove", target = item })
			flash(okU and "Undid last placement" or "Couldn't undo that")
			return
		end
	end
	flash("Nothing to undo")
end

S.addUndoItem = function(item)
	if typeof(item) ~= "Instance" then return end
	table.insert(undoStack, item)
	if #undoStack > 40 then table.remove(undoStack, 1) end
end

S.sendStructureSegment = function(action, ax, az, bx, bz)
	local ok, result = buildRemote:InvokeServer({
		action = action, level = currentLevel,
		ax = ax, az = az, bx = bx, bz = bz,
		mat = selectedMaterial, t = selectedTransparency,
		r = selectedColor.R, g = selectedColor.G, b = selectedColor.B,
		shape = (action == "roof") and roofShape or nil,
		pitch = (action == "roof") and roofPitch or nil,
		roofRotation = (action == "roof") and S.roofRotation or nil,
		roofSnap = (action == "roof") and S.roofSnap or nil,
		overhang = (action == "roof") and S.roofOverhang or nil,
		verticalOffset = (action == "roof") and -ROOF_FLOOR_GAP or nil,
		height = (action == "wall") and WALL_HEIGHT or nil,
		thickness = (action == "wall") and 0.5 or nil,
	})
	if not ok then
		flash(tostring(result or "Build rejected"))
		return false
	end
	S.addUndoItem(result)
	if action == "wall" and S.WallSnap and S.activePlot then
		S.WallSnap.Invalidate(S.activePlot)
	end
	task.defer(refreshLevelView)
	return true
end

S.beginStructureDrag = function()
	local p = planePoint()
	if not p then flash("Stand on your plot to build!") return end
	clearStructure()
	local cx, cz = snapStruct(p)
	S.roofStartSnapped = false
	if mode == "wall" then
		cx, cz = S.snapWallPoint(cx, cz)
	elseif mode == "roof" then
		cx, cz, S.roofStartSnapped = S.snapRoofPoint(cx, cz)
	end
	structStart = Vector3.new(cx, p.Y, cz)
	S.structEndX, S.structEndZ = cx, cz
	S.structDragging = true
	S.buildTouchActive = true -- suppress orbit for the duration of this drag

	if mode == "wall" and S.wallMode == "box" then
		structPreview = Instance.new("Model")
		structPreview.Name = "WallBoxPreview"
		structPreview.Parent = camera
		S.createPreviewPart(structPreview, "North")
		S.createPreviewPart(structPreview, "South")
		S.createPreviewPart(structPreview, "West")
		S.createPreviewPart(structPreview, "East")
	else
		structPreview = S.createPreviewPart(camera, "StructurePreview")
	end
end

S.commitStructureDrag = function()
	if not (S.structDragging and structStart) then return end
	S.structDragging = false
	local cx, cz = S.structEndX or structStart.X, S.structEndZ or structStart.Z

	if mode == "wall" then
		if S.wallMode == "box" then
			local x1, x2 = math.min(structStart.X, cx), math.max(structStart.X, cx)
			local z1, z2 = math.min(structStart.Z, cz), math.max(structStart.Z, cz)
			if math.abs(x2 - x1) < 0.5 or math.abs(z2 - z1) < 0.5 then
				flash("Drag a wider box")
			else
				S.sendStructureSegment("wall", x1, z1, x2, z1)
				S.sendStructureSegment("wall", x2, z1, x2, z2)
				S.sendStructureSegment("wall", x2, z2, x1, z2)
				S.sendStructureSegment("wall", x1, z2, x1, z1)
			end
		else
			local length = (Vector2.new(cx, cz) - Vector2.new(structStart.X, structStart.Z)).Magnitude
			if length >= 0.5 then
				S.sendStructureSegment("wall", structStart.X, structStart.Z, cx, cz)
			else
				flash("Drag to set the wall length")
			end
		end
	elseif mode == "floor" then
		if math.abs(cx - structStart.X) >= 0.5 and math.abs(cz - structStart.Z) >= 0.5 then
			S.sendStructureSegment("floor", structStart.X, structStart.Z, cx, cz)
		else
			flash("Drag a floor rectangle")
		end
	elseif mode == "roof" then
		if math.abs(cx - structStart.X) >= 0.5 and math.abs(cz - structStart.Z) >= 0.5 then
			-- Send the snapped WALL/GRID footprint. The server applies Edge exactly
			-- once. Older clients expanded here and the server expanded again,
			-- making the saved roof larger than the preview.
			S.sendStructureSegment("roof", structStart.X, structStart.Z, cx, cz)
		else
			flash("Drag a roof rectangle")
		end
	end
	clearStructure()
end

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		if mode == "ghost" then
			-- On touch, a tap MOVES the ghost; the ✔ button places it.
			-- (Otherwise taps placed at the ghost's previous spot.)
			if input.UserInputType ~= Enum.UserInputType.Touch then
				tryPlace()
			end
		elseif mode == "trim" then
			local model, hit = placedHit()
			-- eyedropper active? sample whatever was clicked (trim included)
			if eyedropper and hit and hit.Instance:IsA("BasePart") then
				selectedMaterial = hit.Instance.Material.Name
				selectedColor = hit.Instance.Color
				selectedTransparency = hit.Instance.Transparency
				U.pillSwatch.BackgroundColor3 = selectedColor
				U.pillSwatch.BackgroundTransparency = selectedTransparency
				eyedropper = false
				if eyeBtn then eyeBtn.BackgroundColor3 = C.CARD_BG end
				flash("Style copied - now click a wall face")
				return
			end
			if model and model.Name == "__Wall" and model.PrimaryPart then
				-- work out WHICH FACE was clicked, so trim lands on the side
				-- you're looking at (inside vs outside)
				local side = 1
				if hit then
					local toHit = hit.Position - model.PrimaryPart.Position
					side = (toHit:Dot(model.PrimaryPart.CFrame.RightVector) >= 0) and 1 or -1
				end
				-- uses whatever the Paint pill is holding, so the 💧 eyedropper
				-- samples a material/colour and the trim takes it too
				local ok, err = buildRemote:InvokeServer({
					action = "trim", target = model, style = S.trimStyle, side = side,
					mat = selectedMaterial, t = selectedTransparency,
					r = selectedColor.R, g = selectedColor.G, b = selectedColor.B,
					tagTrim = true, preserveWallStyle = true,
				})
				if not ok and err then flash(tostring(err)) end
			else
				flash("Trim goes on walls")
			end
		elseif mode == "sell" then
			local model = placedHit()
			if not model then model = placedModelUnderMouse() end
			if model then
				local ok, refund = buildRemote:InvokeServer({ action = "sellplaced", target = model })
				if ok then
					flash("Sold for " .. money(refund or 0))
				else
					flash(tostring(refund or "Can't sell that"))
				end
				U.hoverHighlight.Parent = nil
			end
		elseif mode == "remove" then
			local model = placedModelUnderMouse()
			if model then
				buildRemote:InvokeServer({ action = "remove", target = model })
				U.hoverHighlight.Parent = nil
			end
		elseif mode == "paint" then
			local model, hit = placedHit()
			if not model then model = placedModelUnderMouse() end
			if model and eyedropper then
				-- copy from the EXACT part clicked - works on meshes too
				local part = (hit and hit.Instance) or model.PrimaryPart
				if part and part:IsA("BasePart") then
					selectedMaterial = part.Material.Name
					selectedColor = part.Color
					selectedTransparency = part.Transparency
					U.pillSwatch.BackgroundColor3 = selectedColor
					U.pillSwatch.BackgroundTransparency = selectedTransparency
					eyedropper = false
					if eyeBtn then eyeBtn.BackgroundColor3 = C.CARD_BG end
					flash("Style copied!")
				end
			elseif model then
				local part = (hit and hit.Instance) or model.PrimaryPart
				buildRemote:InvokeServer({
					action = "paint", target = model, part = part,
					paintScope = "part", preserveTrim = true,
					mat = selectedMaterial,
					r = selectedColor.R, g = selectedColor.G, b = selectedColor.B,
					t = selectedTransparency,
				})
			end
		elseif mode == "select" then
			-- A copied item/group follows the cursor until this click drops it.
			if floatingCopies then
				S.stampHeld = S.stampMode
				S.dropFloatingCopies(S.stampMode)
				return
			end

			-- Never steal a click that belongs to a Studio handle.
			if handleGrab or dragStart or rotStart or sizeStart then return end

			local hitModel = placedHit()
			if not hitModel then hitModel = placedModelUnderMouse() end

			-- Clicking any member of a lasso selection drags the whole group.
			if hitModel and boxSelection[hitModel] then
				groupDragActive = true
				groupDragY = hitModel:GetPivot().Position.Y
				local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
				local t = (groupDragY - unitRay.Origin.Y) / unitRay.Direction.Y
				local grab = unitRay.Origin + unitRay.Direction * t
				groupDragOrigin = Vector3.new(grab.X, groupDragY, grab.Z)
				groupStartPivots = {}
				for model in pairs(boxSelection) do
					groupStartPivots[model] = model:GetPivot()
				end
				S.groupProxyStart = groupProxy.CFrame
				return
			end

			if hitModel == selModel and selModel then
				local pivot = selModel:GetPivot()
				dragSelPending = true
				dragSelStart = input.Position
				dragSelY = pivot.Position.Y
				local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
				local t = (dragSelY - unitRay.Origin.Y) / unitRay.Direction.Y
				local grab = unitRay.Origin + unitRay.Direction * t
				dragSelOffset = Vector3.new(pivot.Position.X - grab.X, 0, pivot.Position.Z - grab.Z)
			elseif hitModel then
				select(hitModel)
				flash("Selected: " .. hitModel.Name:gsub("__", ""))
			else
				-- Empty-space drag starts lasso; empty click clears on release.
				dragSelPending = false
				S.boxPressModel = nil
				boxDragStart = Vector2.new(input.Position.X, input.Position.Y)
				U.boxFrame.Position = UDim2.fromOffset(boxDragStart.X, boxDragStart.Y)
				U.boxFrame.Size = UDim2.fromOffset(0, 0)
				U.boxFrame.Visible = true
			end
		elseif mode == "roof" and S.roofMode == "trace" then
			addTracePoint()
		elseif mode == "roof" and S.roofMode == "auto" then
			S.buildAutoRoofRef()
		elseif mode == "wall" or mode == "floor" or mode == "roof" then
			S.beginStructureDrag()
		end
	elseif input.KeyCode == Enum.KeyCode.R then
		-- Bloxburg-style quick turn: plain R rotates the active build object.
		if mode == "ghost" then
			ghostRotation += ghostWallKind and math.pi or math.rad(90)
		elseif mode == "roof" then
			S.roofRotation = (S.roofRotation + 90) % 180
			S.roofGhostSig = nil
			flash("Roof turned " .. S.roofRotation .. "°")
		elseif mode == "select" then
			if boxSelectionCount() > 0 then
				groupRotateRef(90)
			elseif selModel then
				selRotateRef(90)
			end
		end
	elseif input.KeyCode == Enum.KeyCode.C and mode == "select" then
		S.toggleStamp()
	elseif input.KeyCode == Enum.KeyCode.Delete or input.KeyCode == Enum.KeyCode.X then
		if boxSelectionCount() > 0 then
			groupDeleteRef()
		elseif mode == "select" and selModel then
			deleteSelected()
		end
	elseif input.KeyCode == Enum.KeyCode.D and mode == "select"
		and (UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
			or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)) then
		-- v9 FIX: copy is Ctrl+D now. Bare D is the WASD strafe key, so
		-- walking right with a wall/floor selected silently cloned it in
		-- place - that was the "duplicates every 3-5 seconds" bug.
		-- Mobile players use the Copy button instead.
		if boxSelectionCount() > 0 then
			groupDupeRef()
		elseif selModel then
			duplicateSelected()
		end
	elseif input.KeyCode == Enum.KeyCode.T then
		local ctrl = UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
			or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)
		if ctrl then
			setMode("select")
			flash("Select: click one item or drag empty space to lasso")
		elseif mode == "select" then
			if boxSelectionCount() > 0 then
				S.groupFlipVertical()
			elseif selModel then
				S.flipSelectedVertical()
			end
		end
	elseif input.KeyCode == Enum.KeyCode.Z
		and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
		if U.dock.Visible then undoLast() end
	elseif input.KeyCode == Enum.KeyCode.Escape then
		-- first Escape puts the tool down, a second one leaves build mode
		if mode ~= nil then
			setMode(nil)
		elseif U.shop.Visible then
			U.shop.Visible = false
		elseif U.dock.Visible then
			closeBuildModeRef()
		end
	end
end)

