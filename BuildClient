-- ⧉ DUPLICATE: start placing another copy of the selected furniture,
-- matching its rotation and scale (Bloxburg-style copy/paste)
duplicateSelected = function()
	if not selModel then return end
	-- Same behaviour as lasso-copy: clone in place (keeping size,
	-- rotation and paint), then the copy sticks to the cursor.
	local source = selModel
	local pivot = source:GetPivot()
	local rx, ry, rz = pivot:ToOrientation()
	local scale = 1
	pcall(function() scale = source:GetScale() end)

	local ok, copy = buildRemote:InvokeServer({
		action = "clone", target = source,
		x = pivot.Position.X, y = pivot.Position.Y, z = pivot.Position.Z,
		rx = rx, rot = ry, rz = rz, scale = scale,
	})
	if not (ok and typeof(copy) == "Instance") then
		flash(tostring(copy or "Couldn't copy that"))
		return
	end

	deselect()
	setMode("select") -- merged Select tool owns follow-the-cursor placement
	local h = Instance.new("Highlight")
	h.FillColor = C.ACCENT
	h.OutlineColor = C.ACCENT
	h.FillTransparency = 0.55
	h.Parent = copy
	boxSelection[copy] = h
	U.boxCount.Text = "1 selected"
	U.boxBar.Visible = true
	refreshGroupHandlesRef()

	floatingCopies = true
	groupStartPivots = { [copy] = copy:GetPivot() }
	groupDragY = copy:GetPivot().Position.Y
	local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
	local t = (groupDragY - unitRay.Origin.Y) / unitRay.Direction.Y
	local grab = unitRay.Origin + unitRay.Direction * t
	groupDragOrigin = Vector3.new(grab.X, groupDragY, grab.Z)
	S.groupProxyStart = groupProxy.CFrame
	flash("Copied - move the mouse, then CLICK to place")
end

S.stackSelected = function()
	if not selModel then return end
	if not S.isStructure(selModel) then
		flash("Stack Up is for walls, floors, and roofs")
		return
	end
	local source = selModel
	local plot = plotOfModel(source)
	local oldLevel = buildLevelOfModel(source, plot)
	if oldLevel >= MAX_LEVEL then
		flash("That is already on the top floor")
		return
	end
	local pivot = source:GetPivot()
	local rx, ry, rz = pivot:ToOrientation()
	local scale = 1
	pcall(function() scale = source:GetScale() end)
	local ok, copy = buildRemote:InvokeServer({
		action = "clone", target = source, level = oldLevel + 1,
		x = pivot.Position.X, y = pivot.Position.Y + WALL_HEIGHT, z = pivot.Position.Z,
		rx = rx, rot = ry, rz = rz, scale = scale, stack = true,
	})
	if not (ok and typeof(copy) == "Instance") then
		flash(tostring(copy or "Couldn't stack that"))
		return
	end
	S.addUndoItem(copy)
	select(copy)
	currentLevel = math.clamp(oldLevel + 1, MIN_LEVEL, MAX_LEVEL)
	for lvl, btn in pairs(U.levelButtons) do
		btn.BackgroundColor3 = (lvl == currentLevel) and C.ACCENT or C.CARD_BG
		btn.TextColor3 = (lvl == currentLevel) and C.WHITE or C.TEXT_GRAY
	end
	lockBuildPlane(); refreshGridPlane(); refreshLevelView()
	flash("Stacked one story up")
end
