	padBtn("▼", 50, 74, function() touchMove.fwd = -1 end,  function() touchMove.fwd = 0 end)
	padBtn("↑", 2, 0,   function() touchMove.up = 1 end,    function() touchMove.up = 0 end)
	padBtn("↓", 98, 0,  function() touchMove.up = -1 end,   function() touchMove.up = 0 end)

	-- drag anywhere on empty screen to look around while flying
	UserInputService.TouchMoved:Connect(function(touch, gameProcessed)
		-- Orbit on single-finger drag while flying (desktop free-cam on touch)
		-- OR while the mobile orbit camera is active. gameProcessed is true when
		-- the touch started on a button, so dragging the toolbar never spins the
		-- camera.
		local mobileOrbit = S.isMobileLayout and S.isMobileLayout() and U.dock.Visible
		if not (flying or mobileOrbit) or gameProcessed then return end
		-- v10.2: hard isolation. A single finger orbits ONLY when no build tool
		-- is active AND no build gesture is in progress. When a tool is up, the
		-- finger belongs to building; the camera moves with two fingers.
		if mobileOrbit and (mode ~= nil
			or S.buildTouchActive == true
			or (S.isManipulating and S.isManipulating())) then
			return
		end
		if mobileOrbit then
			-- single finger = HORIZONTAL orbit only (yaw). CLAMP the per-event
			-- change so a fast flick can't throw the camera across the map
			-- (touch velocity spikes were the "hyper-speed" symptom).
			local dYaw = math.clamp(touch.Delta.X * 0.0007, -0.06, 0.06)
			camYaw -= dYaw
		else
			local sens = 0.006
			camYaw -= touch.Delta.X * sens
			camPitch = math.clamp(camPitch - touch.Delta.Y * sens, -1.4, 1.4)
		end
	end)

	-- The per-frame camera step. v9: this is CONNECTED only while flying
	-- and disconnected on landing (no idle per-frame work, ever).
	local camConn = nil
	local function camStep(dt)
		-- v10.1: under the mobile LAYOUT the orbit rig owns the camera. If this
		-- free-cam loop is somehow still connected, do nothing - two camera
		-- systems writing camera.CFrame is what made a single finger appear to
		-- move the camera during a wall drag.
		if S.isMobileLayout and S.isMobileLayout() then return end
		-- look while holding right mouse
		if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
			UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
			local delta = UserInputService:GetMouseDelta()
			camYaw -= delta.X * 0.005
			camPitch = math.clamp(camPitch - delta.Y * 0.005, -1.4, 1.4)
		else
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		end

		local rot = CFrame.fromEulerAnglesYXZ(camPitch, camYaw, 0)
		local speed = S.freeCamSpeed * (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 2.5 or 1)
		local move = Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then move += rot.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then move -= rot.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then move += rot.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then move -= rot.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.E) then move += Vector3.yAxis end
		if UserInputService:IsKeyDown(Enum.KeyCode.Q) then move -= Vector3.yAxis end
		-- touch pad input
		move += rot.LookVector * touchMove.fwd
		move += rot.RightVector * touchMove.side
		move += Vector3.yAxis * touchMove.up
		if move.Magnitude > 0 then
			camPos += move.Unit * speed * dt
		end
		camera.CFrame = CFrame.new(camPos) * rot
	end
	S.setCamLoopRef = function(on)
		if on and not camConn then
			camConn = RunService.RenderStepped:Connect(camStep)
		elseif not on and camConn then
			camConn:Disconnect()
			camConn = nil
		end
	end

	--------------------------------------------------------------------
	-- BUILD-MODE TIME PREVIEW (client-side ONLY: your screen changes,
