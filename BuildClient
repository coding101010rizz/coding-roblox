-- While build mode is open, hide the player's OTHER interfaces so the
-- screen stays clean. This only touches OUR PlayerGui, so nobody else is
-- affected.
local hiddenGuis = {}
-- ours, the clock, and the wallet (you need to see money while shopping)
local KEEP_VISIBLE = { BuildUI = true, ClockUI = true, WalletUI = true }

-- v9: every GUI we disable is TAGGED with an attribute. Recovery below
-- only wakes tagged interfaces, so GUIs that OTHER systems keep disabled
-- on purpose (extra inventory panels, templates) are left alone. This is
-- the fix for the "two inventories" bug.
local RESTORE_ON_START = true

local function setOtherUIsVisible(visible)
	local pg = player:FindFirstChildOfClass("PlayerGui")
	if not pg then return end
	local ok, err = pcall(function()
		if visible then
			-- restore ONLY what we hid, and clear the tags
			for g in pairs(hiddenGuis) do
				if g and g.Parent then
					g.Enabled = true
					g:SetAttribute("BuildUIHid", nil)
				end
			end
			table.clear(hiddenGuis)
		else
			for _, g in ipairs(pg:GetChildren()) do
				if g:IsA("ScreenGui") and not KEEP_VISIBLE[g.Name] and g.Enabled then
					hiddenGuis[g] = true
					g:SetAttribute("BuildUIHid", true)
					g.Enabled = false
				end
			end
		end
	end)
	if not ok then
		warn("[Build] UI visibility error: " .. tostring(err))
	end
end

if RESTORE_ON_START then
	task.defer(function()
		local pg = player:FindFirstChildOfClass("PlayerGui")
		if not pg then return end
		local fixed = 0
		for _, g in ipairs(pg:GetChildren()) do
			-- only interfaces WE disabled in a previous session carry the tag
			if g:IsA("ScreenGui") and not g.Enabled and g:GetAttribute("BuildUIHid") then
				g.Enabled = true
				g:SetAttribute("BuildUIHid", nil)
				fixed += 1
			end
		end
		if fixed > 0 then
			print("[Build] re-enabled " .. fixed .. " interface(s) this script hid in a previous session")
		end
	end)
end

-- LEAVING YOUR PLOT closes build mode, so you can't build from next door.
-- v9: checked on the CLIENT (zero remote calls) and only scheduled while
-- the dock is open - no idle polling, no per-2s server invokes.
S.plotWatchToken = 0
S.startPlotWatch = function()
	S.plotWatchToken += 1
	local token = S.plotWatchToken
	local function step()
		if token ~= S.plotWatchToken or not U.dock.Visible then return end
		if myPlotPart() ~= S.homePlot then
			closeBuildModeRef()
			U.toast.Text = "Left your plot - build mode closed"
			U.toast.TextColor3 = C.RED
			U.toast.Visible = true
			task.delay(2.6, function() U.toast.Visible = false end)
			return
		end
		task.delay(2, step)
	end
	task.delay(2, step)
end

-- Everything that must happen when build mode closes, in one place:
-- tools off, shop closed, other interfaces back, selections dropped.
-- (free-cam lands itself via the dock listener once the dock is hidden.)
local function closeBuildMode()
	S.plotWatchToken += 1 -- cancel any pending plot-watch step
	U.dock.Visible = false
	player:SetAttribute("BuildDockOpen", false) -- ClockUI reappears
	U.shop.Visible = false
	setWalletVisible(true)
	setMode(nil)
	deselect()
	S.clearTraceRef()
	S.resetLevelView()
	setOtherUIsVisible(true)
end

