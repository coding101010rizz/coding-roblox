-- Selection bounds helpers
local function plotOfModel(model)
	if not plotsFolderRef then return nil end
	local pivot = model:GetPivot().Position
	for _, plot in ipairs(plotsFolderRef:GetChildren()) do
		if plot:IsA("BasePart") then
			local rel = plot.CFrame:PointToObjectSpace(pivot)
			if math.abs(rel.X) <= plot.Size.X/2 + 2 and math.abs(rel.Z) <= plot.Size.Z/2 + 2 then
				return plot
			end
		end
	end
	return nil
end

local function buildLevelOfModel(model, plot)
	local tagged = model:GetAttribute("Level")
	if typeof(tagged) == "number" then return math.round(tagged) end
	plot = plot or plotOfModel(model)
	if not plot then return 0 end
	local plotTop = plot.Position.Y + plot.Size.Y / 2
	local baseY
	if model.Name == "__Wall" and model.PrimaryPart then
		baseY = model.PrimaryPart.Position.Y - model.PrimaryPart.Size.Y / 2
	elseif model.Name == "__Roof" then
		local _, size = model:GetBoundingBox()
		baseY = model:GetPivot().Position.Y - math.max(size.Y / 2, 0) - WALL_HEIGHT + ROOF_FLOOR_GAP
	else
		local box, size = model:GetBoundingBox()
		baseY = box.Position.Y - size.Y / 2
	end
	return math.clamp(math.round((baseY - plotTop) / WALL_HEIGHT), MIN_LEVEL, MAX_LEVEL)
end

