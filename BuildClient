-- v9.7 PLACEMENT GUIDELINES: two thin bright lines through the current
-- placement point, spanning the plot, so wall/floor/roof edges are easy to
-- line up on mobile (and helpful on PC too). Pooled - created once, moved
-- and shown/hidden. Purely visual, on the client, never sent to the server.
S.guideLines = nil
S.showGuidelines = function(x, z, y)
	if not S.guideLines then
		S.guideLines = {}
		for i = 1, 2 do
			local line = Instance.new("Part")
			line.Name = "BuildGuide" .. i
			line.Anchored = true
			line.CanCollide = false
			line.CanTouch = false
			line.CanQuery = false
			line.CastShadow = false
			line.Material = Enum.Material.Neon
			line.Color = C.GOLD
			line.Transparency = 0.35
			line.Parent = camera
			S.guideLines[i] = line
		end
	end
	local plot = S.activePlot or myPlotPart()
	if not plot then S.hideGuidelines() return end
	local gy = (y or buildPlaneY() or plot.Position.Y) + 0.06
	-- line 1 runs along the plot's X extent at this Z; line 2 along Z at this X
	local along = plot.CFrame.RightVector
	local across = plot.CFrame.LookVector
	local lenX, lenZ = plot.Size.X, plot.Size.Z
	local p = Vector3.new(x, gy, z)
	S.guideLines[1].Size = Vector3.new(lenX, 0.08, 0.08)
	S.guideLines[1].CFrame = CFrame.lookAt(p, p + across) * CFrame.Angles(0, math.rad(90), 0)
	S.guideLines[2].Size = Vector3.new(0.08, 0.08, lenZ)
	S.guideLines[2].CFrame = CFrame.lookAt(p, p + across)
	for _, l in ipairs(S.guideLines) do l.Transparency = 0.35 end
end
S.hideGuidelines = function()
	if S.guideLines then
		for _, l in ipairs(S.guideLines) do l.Transparency = 1 end
	end
end

