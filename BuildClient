--------------------------------------------------------------------
-- ROOF TRACING: drop points on wall corners (like editing vertices) and
-- the roof is generated over the outline you draw.
--------------------------------------------------------------------
S.tracePoints = {}     -- Vector3 outline, in order
S.traceDots = {}       -- the visible markers
S.traceGhost = nil     -- live roof preview over the outline
S.snapDots = {}        -- candidate corners harvested from your walls

local function clearTrace()
	for _, d in ipairs(S.traceDots) do d:Destroy() end
	for _, d in ipairs(S.snapDots) do d:Destroy() end
	table.clear(S.traceDots)
	table.clear(S.snapDots)
	table.clear(S.tracePoints)
	if S.traceGhost then S.traceGhost:Destroy() S.traceGhost = nil end
	U.traceBar.Visible = false
end

local function marker(pos, colour, size)
	local p = Instance.new("Part")
	p.Shape = Enum.PartType.Ball
	p.Size = Vector3.one * (size or 1.1)
	p.Position = pos
	p.Anchored = true
	p.CanCollide = false
	p.CanQuery = false
	p.Material = Enum.Material.Neon
	p.Color = colour
	p.Parent = camera
	return p
end

-- collect the ends of every wall on this level: those are the corners
-- you'll usually want to trace around
local function harvestCorners()
	for _, d in ipairs(S.snapDots) do d:Destroy() end
	table.clear(S.snapDots)
	if not itemsRoot then return end
	local planeY = buildPlaneY()
	if not planeY then return end
	local seen = {}
	for _, plotFolder in ipairs(itemsRoot:GetChildren()) do
		for _, m in ipairs(plotFolder:GetChildren()) do
			if m:IsA("Model") and m.Name == "__Wall" and m.PrimaryPart
				and plotOfModel(m) == (S.activePlot or myPlotPart()) then
				local part = m.PrimaryPart
				-- only walls belonging to this storey
				if math.abs((part.Position.Y - part.Size.Y / 2) - planeY) < 1.5 then
					for _, dir in ipairs({ 1, -1 }) do
						local p = (part.CFrame * CFrame.new(0, -part.Size.Y / 2, dir * part.Size.Z / 2)).Position
						local key = math.floor(p.X + 0.5) .. "," .. math.floor(p.Z + 0.5)
						if not seen[key] then
							seen[key] = true
							table.insert(S.snapDots, marker(Vector3.new(p.X, planeY + WALL_HEIGHT, p.Z),
								Color3.fromRGB(255, 214, 102), 0.9))
						end
					end
				end
			end
		end
	end
end

local function refreshTraceGhost()
	if S.traceGhost then S.traceGhost:Destroy() S.traceGhost = nil end
	if #S.tracePoints < 3 or not RoofShapes then return end
	local planeY = buildPlaneY()
	if not planeY then return end

	local minX, maxX = math.huge, -math.huge
	local minZ, maxZ = math.huge, -math.huge
	for _, p in ipairs(S.tracePoints) do
		minX, maxX = math.min(minX, p.X), math.max(maxX, p.X)
		minZ, maxZ = math.min(minZ, p.Z), math.max(maxZ, p.Z)
	end
	local span = math.min(maxX - minX, maxZ - minZ)
	if span < 2 then return end
	local rise = math.clamp(span * 0.35 * roofPitch, 1, 14)

	local pieces = RoofShapes.BuildPolygon(S.tracePoints, planeY + WALL_HEIGHT, rise,
		(roofShape == "flat") and "flat" or "hip")
	if #pieces == 0 then return end
	local model = Instance.new("Model")
	for _, piece in ipairs(pieces) do
		local p = Instance.new(piece.wedge and "WedgePart" or "Part")
		p.Size = piece.size
		p.CFrame = piece.cf
		p.Anchored = true
		p.CanCollide = false
		p.CanQuery = false
		p.Material = Enum.Material.SmoothPlastic
		p.Color = C.ACCENT
		p.Transparency = 0.45
		p.Parent = model
	end
	model.Parent = camera
	S.traceGhost = model
end

local function addTracePoint()
	local p = planePoint()
	if not p then flash("Stand on your plot to trace") return end
	local planeY = buildPlaneY()

	-- snap to the nearest harvested corner if we're close to one
	local best, bestDist = nil, 6
	for _, dot in ipairs(S.snapDots) do
		local d = (Vector3.new(dot.Position.X, 0, dot.Position.Z) - Vector3.new(p.X, 0, p.Z)).Magnitude
		if d < bestDist then best, bestDist = dot, d end
	end
	local point
	if best then
		point = Vector3.new(best.Position.X, 0, best.Position.Z)
	else
		local sx, sz = snapStruct(p)
		point = Vector3.new(sx, 0, sz)
	end

	-- clicking the first dot again closes the loop and builds
	if #S.tracePoints >= 3 then
		local first = S.tracePoints[1]
		if (Vector3.new(first.X, 0, first.Z) - point).Magnitude < 3 then
			S.buildTracedRoofRef()
			return
		end
	end

	table.insert(S.tracePoints, point)
	table.insert(S.traceDots, marker(Vector3.new(point.X, (planeY or 0) + WALL_HEIGHT, point.Z), C.ACCENT, 1.2))
	U.traceBar.Visible = true
	U.traceCount.Text = #S.tracePoints .. " points"
	refreshTraceGhost()
end

buildTracedRoof = function()
	if #S.tracePoints < 3 then flash("Need at least 3 points") return end
	local pts = {}
	for _, p in ipairs(S.tracePoints) do
		table.insert(pts, { x = p.X, z = p.Z })
	end
	local ok, err = buildRemote:InvokeServer({
		action = "roofpoly", points = pts, level = currentLevel,
		pitch = roofPitch, shape = roofShape,
		roofRotation = S.roofRotation, roofSnap = S.roofSnap,
		overhang = S.roofOverhang, verticalOffset = -ROOF_FLOOR_GAP,
		mat = selectedMaterial, t = selectedTransparency,
		r = selectedColor.R, g = selectedColor.G, b = selectedColor.B,
	})
	if ok then
		flash("Roof built from " .. #pts .. " points")
		clearTrace()
		harvestCorners()
		task.defer(refreshLevelView)
	else
		flash(tostring(err or "Couldn't build that roof"))
	end
end

S.buildAutoRoofRef = function()
	if not itemsRoot then return end
	local planeY = buildPlaneY()
	if not planeY then flash("Stand on your plot first") return end

	local minX, maxX = math.huge, -math.huge
	local minZ, maxZ = math.huge, -math.huge
	local walls = 0
	for _, plotFolder in ipairs(itemsRoot:GetChildren()) do
		for _, model in ipairs(plotFolder:GetChildren()) do
			if model:IsA("Model") and model.Name == "__Wall" and model.PrimaryPart
				and plotOfModel(model) == (S.activePlot or myPlotPart()) then
				local part = model.PrimaryPart
				if math.abs((part.Position.Y - part.Size.Y / 2) - planeY) < 1.5 then
					walls += 1
					local cf, size = model:GetBoundingBox()
					local half = size / 2
					for _, sx in ipairs({ -1, 1 }) do
						for _, sz in ipairs({ -1, 1 }) do
							local point = cf:PointToWorldSpace(Vector3.new(half.X * sx, 0, half.Z * sz))
							minX, maxX = math.min(minX, point.X), math.max(maxX, point.X)
							minZ, maxZ = math.min(minZ, point.Z), math.max(maxZ, point.Z)
						end
					end
				end
			end
		end
	end

	if walls == 0 or minX == math.huge then
		flash("Auto Roof needs walls on this level")
		return
	end
	local overhang = S.roofOverhang or 1
	local ok, result = buildRemote:InvokeServer({
		action = "roof", level = currentLevel,
		-- Raw wall bounds; the server adds Edge once.
		ax = minX, az = minZ,
		bx = maxX, bz = maxZ,
		shape = roofShape, pitch = roofPitch,
		roofRotation = S.roofRotation, roofSnap = S.roofSnap,
		overhang = overhang, verticalOffset = -ROOF_FLOOR_GAP,
		mat = selectedMaterial, t = selectedTransparency,
		r = selectedColor.R, g = selectedColor.G, b = selectedColor.B,
	})
	if ok then
		if typeof(result) == "Instance" then
			table.insert(undoStack, result)
		end
		flash("Auto roof built over " .. walls .. " walls")
		task.defer(refreshLevelView)
	else
		flash(tostring(result or "Auto roof failed"))
	end
end

