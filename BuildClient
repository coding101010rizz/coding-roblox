S.stackGroup = function()
	if boxSelectionCount() == 0 then return end
	local copies, skipped = {}, 0
	for model in pairs(boxSelection) do
		if model.Parent and S.isStructure(model) then
			local oldLevel = buildLevelOfModel(model, plotOfModel(model))
			if oldLevel < MAX_LEVEL then
				local pivot = model:GetPivot()
				local rx, ry, rz = pivot:ToOrientation()
				local scale = 1
				pcall(function() scale = model:GetScale() end)
				local ok, copy = buildRemote:InvokeServer({
					action = "clone", target = model, level = oldLevel + 1, stack = true,
					x = pivot.Position.X, y = pivot.Position.Y + WALL_HEIGHT, z = pivot.Position.Z,
					rx = rx, rot = ry, rz = rz, scale = scale,
				})
				if ok and typeof(copy) == "Instance" then
					table.insert(copies, copy); S.addUndoItem(copy)
				else skipped += 1 end
			else skipped += 1 end
		else skipped += 1 end
	end
	clearBoxSelection()
	for _, copy in ipairs(copies) do
		local h = Instance.new("Highlight")
		h.FillColor = C.ACCENT; h.OutlineColor = C.ACCENT; h.FillTransparency = 0.55
		h.Parent = copy; boxSelection[copy] = h
	end
	U.boxCount.Text = #copies .. " selected"
	U.boxBar.Visible = #copies > 0
	refreshGroupHandles(); refreshLevelView()
	flash("Stacked " .. #copies .. " piece(s)" .. (skipped > 0 and (" • skipped " .. skipped) or ""))
end
