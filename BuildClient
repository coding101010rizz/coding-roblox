-- ⧉ duplicate the whole selection, offset to one side
local function groupDupe()
	local n = boxSelectionCount()
	if n == 0 then return end
	-- copies land EXACTLY on top of the originals; you then drag the
	-- (auto-selected) copies out to where you want them
	local copies, failed = {}, 0
	for model in pairs(boxSelection) do
		if model.Parent then
			-- send the source's CURRENT transform so a copy of a copy
			-- lands on that copy, not back on the original
			local pivot = model:GetPivot()
			local rx, ry, rz = pivot:ToOrientation()
			local mscale = 1
			pcall(function() mscale = model:GetScale() end)
			local ok, res = buildRemote:InvokeServer({
				action = "clone", target = model,
				x = pivot.Position.X, y = pivot.Position.Y, z = pivot.Position.Z,
				rx = rx, rot = ry, rz = rz, scale = mscale,
			})
			if ok and typeof(res) == "Instance" then
				table.insert(copies, res)
			else
				failed += 1
			end
		end
	end

	clearBoxSelection()
	-- select the new copies so they can be dragged straight into place
	for _, copy in ipairs(copies) do
		local h = Instance.new("Highlight")
		h.FillColor = C.ACCENT
		h.OutlineColor = C.ACCENT
		h.FillTransparency = 0.55
		h.Parent = copy
		boxSelection[copy] = h
	end
	U.boxCount.Text = #copies .. " selected"
	U.boxBar.Visible = #copies > 0
	refreshGroupHandles()

	-- pick the copies up immediately: they follow the mouse until you click
	if #copies > 0 then
		floatingCopies = true
		groupStartPivots = {}
		for _, copy in ipairs(copies) do
			groupStartPivots[copy] = copy:GetPivot()
		end
		groupDragY = copies[1]:GetPivot().Position.Y
		local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
		local t = (groupDragY - unitRay.Origin.Y) / unitRay.Direction.Y
		local grab = unitRay.Origin + unitRay.Direction * t
		groupDragOrigin = Vector3.new(grab.X, groupDragY, grab.Z)
		S.groupProxyStart = groupProxy.CFrame
	end
	flash("Copied " .. #copies .. " - move the mouse, then CLICK to place")
end

