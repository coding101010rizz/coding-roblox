-- BUILD PLANE (construction happens ON this, at the selected level)
--------------------------------------------------------------------
local plotsFolderRef = workspace:WaitForChild("Plots", 10)
local gridPlane = nil
-- (refreshGridPlane is forward-declared near the top of the file)

local function myPlotPart()
	if not plotsFolderRef then return nil end
	local char = player.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then return nil end
	for _, plot in ipairs(plotsFolderRef:GetChildren()) do
		if plot:IsA("BasePart") then
			local rel = plot.CFrame:PointToObjectSpace(root.Position)
			if math.abs(rel.X) <= plot.Size.X/2 + 6 and math.abs(rel.Z) <= plot.Size.Z/2 + 6 then
				return plot
			end
		end
	end
	return nil
end

-- The plot and plane height are LOCKED IN when a construction tool is
-- activated (and when the level changes). Recomputing them every frame
-- from the character's position is what made the guideline wobble.
S.activePlot, S.activePlaneY = nil, nil

local function buildPlaneY()
	if S.activePlaneY then return S.activePlaneY end
	local plot = myPlotPart()
	if not plot then return nil end
	return plot.Position.Y + plot.Size.Y/2 + currentLevel * WALL_HEIGHT
end

lockBuildPlane = function()
	S.activePlot = myPlotPart()
	S.activePlaneY = S.activePlot
		and (S.activePlot.Position.Y + S.activePlot.Size.Y/2 + currentLevel * WALL_HEIGHT)
		or nil
end

releaseBuildPlane = function()
	S.activePlot, S.activePlaneY = nil, nil
end

refreshGridPlane = function()
	if gridPlane then gridPlane:Destroy() gridPlane = nil end
	if not U.dock.Visible then return end
	local plot = S.activePlot or myPlotPart()
	local y = buildPlaneY()
	if not (plot and y) then return end

	-- A single non-queryable surface carries the whole visual grid.  This is
	-- substantially cheaper than spawning one 3D Part for every grid line.
	gridPlane = Instance.new("Part")
	gridPlane.Name = "BuildGrid"
	gridPlane.Size = Vector3.new(plot.Size.X, 0.04, plot.Size.Z)
	-- Roof placement happens at the TOP of the current story. Showing the
	-- grid down on the floor made the cursor footprint look disconnected.
	local gridY = y + ((mode == "roof") and WALL_HEIGHT or 0)
	gridPlane.CFrame = CFrame.new(plot.Position.X, gridY + 0.025, plot.Position.Z) * plot.CFrame.Rotation
	gridPlane.Anchored = true
	gridPlane.CanCollide = false
	gridPlane.CanTouch = false
	gridPlane.CanQuery = false
	gridPlane.CastShadow = false
	gridPlane.Transparency = 0.94
	gridPlane.Color = Color3.fromRGB(248, 251, 255) -- v9: soft light plane
	gridPlane.Material = Enum.Material.SmoothPlastic
	gridPlane.Parent = camera

	local pixelsPerStud = 12
	local surface = Instance.new("SurfaceGui")
	surface.Name = "GridLines"
	surface.Face = Enum.NormalId.Top
	surface.AlwaysOnTop = false
	surface.LightInfluence = 0
	surface.Brightness = 1.5
	surface.CanvasSize = Vector2.new(
		math.max(1, math.floor(plot.Size.X * pixelsPerStud + 0.5)),
		math.max(1, math.floor(plot.Size.Z * pixelsPerStud + 0.5))
	)
	surface.Parent = gridPlane

	local canvasX, canvasY = surface.CanvasSize.X, surface.CanvasSize.Y
	local studsX, studsZ = math.floor(plot.Size.X + 0.5), math.floor(plot.Size.Z + 0.5)
	local function addLine(vertical, stud, totalStuds, totalPixels)
		local major = stud % 4 == 0
		local line = Instance.new("Frame")
		line.Name = major and "Major" or "Minor"
		line.BorderSizePixel = 0
		-- v9: sky-blue pastel grid to match the interface
		line.BackgroundColor3 = major and Color3.fromRGB(96, 175, 255) or Color3.fromRGB(150, 200, 255)
		line.BackgroundTransparency = major and 0.26 or 0.52
		local px = math.max(1, major and 2 or 1)
		local position = math.floor((stud / math.max(totalStuds, 1)) * totalPixels + 0.5)
		if vertical then
			line.Size = UDim2.fromOffset(px, canvasY)
			line.Position = UDim2.fromOffset(math.clamp(position, 0, canvasX - px), 0)
		else
			line.Size = UDim2.fromOffset(canvasX, px)
			line.Position = UDim2.fromOffset(0, math.clamp(position, 0, canvasY - px))
		end
		line.Parent = surface
	end

	for stud = 0, studsX do addLine(true, stud, studsX, canvasX) end
	for stud = 0, studsZ do addLine(false, stud, studsZ, canvasY) end
end

-- Snap a point to the grid RELATIVE TO THE PLOT (grid starts at the
-- plot corner), clamped to its edges - walls/floors align 1:1 with pads
local function snapStruct(point)
	local plot = S.activePlot or myPlotPart()
	if not plot then
		return math.round(point.X / WGRID) * WGRID, math.round(point.Z / WGRID) * WGRID
	end
	local rel = plot.CFrame:PointToObjectSpace(point)
	local hx, hz = plot.Size.X / 2, plot.Size.Z / 2
	local snap = (mode == "roof") and S.roofSnap or WGRID
	local rx = math.clamp(math.round((rel.X + hx) / snap) * snap - hx, -hx, hx)
	local rz = math.clamp(math.round((rel.Z + hz) / snap) * snap - hz, -hz, hz)
	local wp = plot.CFrame:PointToWorldSpace(Vector3.new(rx, rel.Y, rz))
	return wp.X, wp.Z
end

-- Intersect the mouse ray with the build plane (math, not raycast) so
-- upper floors and basements get accurate cursor points
-- Rectangular roofs can magnetize to the same wall corners used by the
-- point-roof tool. This makes Drag Roof feel attached to the building rather
-- than merely rounded to an invisible world grid.
S.snapRoofPoint = function(x, z)
	local bestX, bestZ, bestDist = x, z, math.huge
	local radius = math.max(1.25, (S.roofSnap or 1) * 0.9)
	for _, dot in ipairs(S.snapDots or {}) do
		if dot and dot.Parent then
			local dx, dz = dot.Position.X - x, dot.Position.Z - z
			local distance = math.sqrt(dx * dx + dz * dz)
			if distance < bestDist and distance <= radius then
				bestX, bestZ, bestDist = dot.Position.X, dot.Position.Z, distance
			end
		end
	end
	return bestX, bestZ, bestDist < math.huge
end

local function planePoint()
	local y = buildPlaneY()
	if not y then return nil end
	local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
	local dir = unitRay.Direction
	if math.abs(dir.Y) < 1e-4 then return nil end
	local t = (y - unitRay.Origin.Y) / dir.Y
	if t < 0 or t > 600 then return nil end
	local p = unitRay.Origin + dir * t
	return Vector3.new(p.X, y, p.Z)
end

