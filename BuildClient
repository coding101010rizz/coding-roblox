	S.setCamLoopRef = function(_) end -- real version assigned after camStep

	local function setFlying(on)
		flying = on
		U.flyBtn.BackgroundColor3 = on and C.ACCENT or C.PANEL
		U.flyBtn.TextColor3 = on and C.WHITE or C.TEXT_GRAY
		U.flyPad.Visible = on and UserInputService.TouchEnabled
		U.flySpeedFrame.Visible = on
		local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if on then
			camPos = camera.CFrame.Position
			local look = camera.CFrame.LookVector
			camYaw = math.atan2(-look.X, -look.Z)
			camPitch = math.asin(look.Y)
			camera.CameraType = Enum.CameraType.Scriptable
			if humanoid then
				savedWalkSpeed = humanoid.WalkSpeed
				humanoid.WalkSpeed = 0
			end
			-- Park the character neatly ON THE GROUND (no mid-air freezing),
			-- then anchor so other players see a standing person, not a floater
			if root then
				local params = RaycastParams.new()
				params.FilterType = Enum.RaycastFilterType.Exclude
				params.FilterDescendantsInstances = { player.Character }
				local hit = workspace:Raycast(root.Position, Vector3.new(0, -60, 0), params)
				if hit then
					local look2 = root.CFrame.LookVector
					root.CFrame = CFrame.lookAt(
						Vector3.new(root.Position.X, hit.Position.Y + 3, root.Position.Z),
						Vector3.new(root.Position.X + look2.X, hit.Position.Y + 3, root.Position.Z + look2.Z)
					)
				end
				root.Anchored = true
			end
		else
			camera.CameraType = Enum.CameraType.Custom
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			if humanoid then humanoid.WalkSpeed = savedWalkSpeed end
			if root then root.Anchored = false end
			-- belt and braces: never leave a character frozen
			local ch = player.Character
			if ch then
				local hrp = ch:FindFirstChild("HumanoidRootPart")
				if hrp then hrp.Anchored = false end
				local h = ch:FindFirstChildOfClass("Humanoid")
				if h and h.WalkSpeed == 0 then h.WalkSpeed = savedWalkSpeed end
			end
		end
		S.setCamLoopRef(on) -- connect/disconnect the per-frame camera step
	end

