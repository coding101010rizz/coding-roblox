-- Selected-item dragging (shared by mouse move + touch move)
UserInputService.InputChanged:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseMovement
		and input.UserInputType ~= Enum.UserInputType.Touch then return end
	if floatingCopies and groupStartPivots then
		local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
		if math.abs(unitRay.Direction.Y) > 1e-4 then
			local t = (groupDragY - unitRay.Origin.Y) / unitRay.Direction.Y
			if t > 0 then
				local p = unitRay.Origin + unitRay.Direction * t
				local snapX = S.stampMode and S.copyCellX or moveSnap()
				local snapZ = S.stampMode and S.copyCellZ or moveSnap()
				local delta = Vector3.new(
					math.round((p.X - groupDragOrigin.X) / snapX) * snapX, 0,
					math.round((p.Z - groupDragOrigin.Z) / snapZ) * snapZ
				)
				for model, startPivot in pairs(groupStartPivots) do
					if typeof(model) == "Instance" and model.Parent then
						model:PivotTo(startPivot + delta)
					end
				end
				groupProxy.CFrame = CFrame.new(S.groupProxyStart.Position + delta)
				if S.stampHeld and S.stampMode and not S.stampBusy then
					local movedFromLast = not S.lastStampCenter
						or (groupProxy.Position - S.lastStampCenter).Magnitude >= math.min(S.copyCellX, S.copyCellZ) * 0.8
					if movedFromLast then S.dropFloatingCopies(true) end
				end
			end
		end
	end
	if groupDragActive and groupStartPivots then
		local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
		if math.abs(unitRay.Direction.Y) > 1e-4 then
			local t = (groupDragY - unitRay.Origin.Y) / unitRay.Direction.Y
			if t > 0 then
				local p = unitRay.Origin + unitRay.Direction * t
				local ms = moveSnap()
				local delta = Vector3.new(
					math.round((p.X - groupDragOrigin.X) / ms) * ms, 0,
					math.round((p.Z - groupDragOrigin.Z) / ms) * ms
				)
				for model, startPivot in pairs(groupStartPivots) do
					if model.Parent then model:PivotTo(startPivot + delta) end
				end
				groupProxy.CFrame = CFrame.new(S.groupProxyStart.Position + delta)
			end
		end
	end
	if boxDragStart and handleGrab then
		-- a handle claimed this gesture: abandon the rubber band
		boxDragStart = nil
		U.boxFrame.Visible = false
	end
	if boxDragStart then
		local cur = Vector2.new(input.Position.X, input.Position.Y)
		local topLeft = Vector2.new(math.min(boxDragStart.X, cur.X), math.min(boxDragStart.Y, cur.Y))
		local size = Vector2.new(math.abs(cur.X - boxDragStart.X), math.abs(cur.Y - boxDragStart.Y))
		U.boxFrame.Position = UDim2.fromOffset(topLeft.X, topLeft.Y)
		U.boxFrame.Size = UDim2.fromOffset(size.X, size.Y)
	end
	-- engage a pending item-drag only after real movement AND only if
	-- no handle claimed the gesture first
	if dragSelPending and selModel and not dragSelActive then
		if dragStart or rotStart or sizeStart then
			dragSelPending = false -- a handle won the click
		elseif dragSelStart and (Vector2.new(input.Position.X, input.Position.Y)
			- Vector2.new(dragSelStart.X, dragSelStart.Y)).Magnitude > 5 then
			dragSelActive = true
			takeSnapshot()
		end
	end
	if not (dragSelActive and selModel) then return end
	local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
	if math.abs(unitRay.Direction.Y) < 1e-4 then return end
	local t = (dragSelY - unitRay.Origin.Y) / unitRay.Direction.Y
	if t < 0 then return end
	local p = unitRay.Origin + unitRay.Direction * t
	local pivot = selModel:GetPivot()
	local ms = moveSnap()
	local target = CFrame.new(
		math.round((p.X + dragSelOffset.X) / ms) * ms,
		dragSelY,
		math.round((p.Z + dragSelOffset.Z) / ms) * ms
	) * pivot.Rotation
	selModel:PivotTo(clampToPlot(target, selModel))
	liveSync()
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		S.buildTouchActive = false -- release orbit suppression
		if S.structDragging then S.commitStructureDrag() end
		S.stampHeld = false
		if groupDragActive then
			groupDragActive = false
			local starts = groupStartPivots
			groupStartPivots = nil
			commitGroupRef(starts)
			refreshGroupHandlesRef()
		end
		if boxDragStart then
			local finish = Vector2.new(input.Position.X, input.Position.Y)
			U.boxFrame.Visible = false
			if handleGrab then
				-- handle drag, not a selection gesture: leave things alone
			elseif (finish - boxDragStart).Magnitude > 12 then
				gatherInBox(boxDragStart, finish)
			else
				clearBoxSelection()
				deselect()
			end
			boxDragStart = nil
			S.boxPressModel = nil
		end
		dragSelPending = false
		if dragSelActive then
			dragSelActive = false
			if not commitTransform() then restoreSnapshot() end
		end
	end
end)

