U.moveHandles.MouseDrag:Connect(function(face, distance)
	if groupHandles and groupHandleStart then
		local dir = Vector3.fromNormalId(face)
		local snapped = math.round(distance / moveSnap()) * moveSnap()
		local delta = dir * snapped
		for model, startPivot in pairs(groupHandleStart) do
			if model ~= "__proxy" and typeof(model) == "Instance" and model.Parent then
				model:PivotTo(startPivot + delta)
			end
		end
		groupProxy.CFrame = groupHandleStart.__proxy + delta
		return
	end
	if not (selModel and dragStart) then return end
	local dir = Vector3.fromNormalId(face)
	local snapped = math.round(distance / moveSnap()) * moveSnap()
	local target = clampToPlot(dragStart * CFrame.new(dir * snapped), selModel)
