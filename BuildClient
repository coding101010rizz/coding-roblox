	end
	U.timeButtons[4].BackgroundColor3 = C.ACCENT

	-- One dock listener drives every dock-dependent panel and handles all
	-- exit paths (button, Escape, dying, leaving the plot) - no per-frame
	-- visibility checks anywhere.
	U.dock:GetPropertyChangedSignal("Visible"):Connect(function()
		local open = U.dock.Visible
		U.flyBtn.Visible = open
		U.timeBar.Visible = open
		U.viewFrame.Visible = open
		if open then
			-- v9.6: the mobile LAYOUT now owns the camera via its orbit rig, so
			-- the old auto-free-cam only applies when a touch device is using the
			-- PC layout (the override case). Mobile layout skips this entirely.
			local mobileLayout = S.isMobileLayout and S.isMobileLayout()
			if UserInputService.TouchEnabled and not mobileLayout
				and not S.autoFlewThisSession and not flying then
				S.autoFlewThisSession = true
