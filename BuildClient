end)

local function structStretch(delta)
	local part = selModel and selModel.PrimaryPart
	if not part then return end
	takeSnapshot()
	local sz = part.Size
	if selModel.Name == "__Wall" then
		part.Size = Vector3.new(sz.X, sz.Y, math.max(sz.Z + delta, 2))
	else -- floors/roofs grow on both ground axes
		part.Size = Vector3.new(math.max(sz.X + delta, 2), sz.Y, math.max(sz.Z + delta, 2))
	end
	if not commitTransform() then restoreSnapshot() end
end

S.scaleFurniture = function(delta)
	if not (selModel and not S.isStructure(selModel)) then return end
	takeSnapshot()
	local oldBox, oldSize = selModel:GetBoundingBox()
	local oldBottom = oldBox.Position.Y - oldSize.Y / 2
	local nextScale = math.clamp(selScale + delta, 0.25, 4)
	local ok, scaleErr = pcall(function() selModel:ScaleTo(nextScale) end)
	if not ok then
		restoreSnapshot()
		flash("This furniture model cannot be scaled: " .. tostring(scaleErr))
		return
	end

	-- Keep floor furniture grounded instead of letting scaling sink it into
	-- the plot or rise into the air because the model pivot is off-centre.
	local newBox, newSize = selModel:GetBoundingBox()
	local newBottom = newBox.Position.Y - newSize.Y / 2
	local pivot = selModel:GetPivot()
	selModel:PivotTo(CFrame.new(pivot.Position + Vector3.new(0, oldBottom - newBottom, 0)) * pivot.Rotation)
	selScale = nextScale
	if not commitTransform() then
		restoreSnapshot()
		pcall(function() selScale = selModel:GetScale() end)
		flash("The server rejected that scale. Install the v8 server helper transform branch.")
	end
end

