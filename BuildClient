-- Projected half-extents of an oriented box onto the plot's X/Z axes
local function projectedHalves(relRotation, size)
	local hx, hy, hz = size.X/2, size.Y/2, size.Z/2
	local r, u, l = relRotation.XVector, relRotation.YVector, relRotation.ZVector
	local px = math.abs(r.X)*hx + math.abs(u.X)*hy + math.abs(l.X)*hz
	local pz = math.abs(r.Z)*hx + math.abs(u.Z)*hy + math.abs(l.Z)*hz
	return px, pz
end

-- Clamp a pivot CFrame so the model's footprint stays on its plot
-- (per-axis, orientation-aware - long walls slide along edges freely)
local function clampToPlot(cf, model)
	if not selPlot then return cf end
	local bcf, size = model:GetBoundingBox()
	local pivotToBox = model:GetPivot():ToObjectSpace(bcf)
	local rel = selPlot.CFrame:ToObjectSpace(cf * pivotToBox)
	local px, pz = projectedHalves(rel.Rotation, size)
	local limX = math.max(selPlot.Size.X/2 - px, 0)
	local limZ = math.max(selPlot.Size.Z/2 - pz, 0)
	local clampedBox = CFrame.new(
		math.clamp(rel.Position.X, -limX, limX),
		rel.Position.Y,
		math.clamp(rel.Position.Z, -limZ, limZ)
	) * rel.Rotation
	return selPlot.CFrame:ToWorldSpace(clampedBox) * pivotToBox:Inverse()
end

-- Stream the drag to the server (throttled) so OTHER players watch it
-- move live instead of it teleporting on release
local lastSync = 0
local function liveSync()
	if os.clock() - lastSync < 0.15 then return end
	lastSync = os.clock()
	task.spawn(commitTransform)
end

-- Snapshot to restore if the server rejects the final position
local gestureSnapshot = nil
local function takeSnapshot()
	if not selModel then return end
	gestureSnapshot = { pivot = selModel:GetPivot() }
	pcall(function() gestureSnapshot.scale = selModel:GetScale() end)
	local part = selModel.PrimaryPart
	if part then
		gestureSnapshot.size = part.Size
		gestureSnapshot.cf = part.CFrame
	end
end
local function restoreSnapshot()
	if not (selModel and gestureSnapshot) then return end
	if S.isStructure(selModel) and selModel.PrimaryPart and gestureSnapshot.size then
		selModel.PrimaryPart.Size = gestureSnapshot.size
		selModel.PrimaryPart.CFrame = gestureSnapshot.cf
	else
		if gestureSnapshot.scale then
			pcall(function() selModel:ScaleTo(gestureSnapshot.scale) end)
			selScale = gestureSnapshot.scale
		end
		selModel:PivotTo(gestureSnapshot.pivot)
	end
end

