local function px(parent, w, h, x, y, colour, rot, radius)
	local f = Instance.new("Frame")
	f.Size = UDim2.fromOffset(w, h)
	f.Position = UDim2.fromOffset(x, y)
	f.BackgroundColor3 = colour
	f.BorderSizePixel = 0
	f.Rotation = rot or 0
	f.Parent = parent
	if radius then
		local uc = Instance.new("UICorner")
		uc.CornerRadius = UDim.new(0, radius)
		uc.Parent = f
	end
	return f
end

local function drawIcon(parent, kind, tint)
	local holder = Instance.new("Frame")
	holder.Size = UDim2.fromOffset(24, 24)
	holder.BackgroundTransparency = 1
	holder.Name = "Icon"
	holder.Parent = parent
	local col = tint or C.TEXT_GRAY
	local dark = C.CARD_BG -- cut-outs match the light card behind the icon

	if kind == "build" then                     -- compact hammer
		px(holder, 14, 4, 3, 5, col, -35, 2)
		px(holder, 4, 15, 12, 8, col, -35, 2)
		px(holder, 8, 3, 1, 8, col, -35, 1)
	elseif kind == "move" then                        -- four-way arrows
		px(holder, 3, 20, 11, 2, col, 0, 2)
		px(holder, 20, 3, 2, 11, col, 0, 2)
		px(holder, 7, 3, 8, 4, col, 45, 1)
		px(holder, 7, 3, 9, 4, col, -45, 1)
	elseif kind == "wall" then                    -- brick courses
		px(holder, 20, 5, 2, 3, col, 0, 1)
		px(holder, 20, 5, 2, 10, col, 0, 1)
		px(holder, 20, 5, 2, 17, col, 0, 1)
	elseif kind == "floor" then                   -- receding plane
		px(holder, 20, 4, 2, 14, col, 0, 1)
		px(holder, 14, 3, 5, 9, col, 0, 1)
		px(holder, 8, 2, 8, 5, col, 0, 1)
	elseif kind == "roof" then                    -- two meeting slopes
		px(holder, 16, 3, 0, 12, col, -32, 1)
		px(holder, 16, 3, 8, 12, col, 32, 1)
	elseif kind == "paint" then                   -- brush
		px(holder, 12, 11, 6, 2, col, 0, 5)
		px(holder, 4, 9, 10, 13, col, 0, 2)
	elseif kind == "delete" then                  -- bin
		px(holder, 16, 3, 4, 5, col, 0, 1)
		px(holder, 6, 2, 9, 2, col, 0, 1)
		px(holder, 13, 14, 5, 9, col, 0, 2)
	elseif kind == "save" then                    -- disk
		px(holder, 18, 18, 3, 3, col, 0, 3)
		px(holder, 9, 5, 8, 4, dark, 0, 1)
		px(holder, 12, 7, 6, 13, dark, 0, 1)
	elseif kind == "bulldoze" then                -- burst
		px(holder, 18, 3, 3, 11, col, 0, 1)
		px(holder, 18, 3, 3, 11, col, 60, 1)
		px(holder, 18, 3, 3, 11, col, -60, 1)
	elseif kind == "undo" then                    -- back arrow
		px(holder, 15, 3, 5, 10, col, 0, 1)
		px(holder, 8, 3, 3, 7, col, 45, 1)
		px(holder, 8, 3, 3, 13, col, -45, 1)
	elseif kind == "trim" then                    -- wall with edge mouldings
		px(holder, 18, 12, 3, 6, col, 0, 1)
		px(holder, 22, 3, 1, 3, col, 0, 1)
		px(holder, 22, 3, 1, 18, col, 0, 1)
	elseif kind == "sell" then                    -- coin heading out
		px(holder, 14, 14, 2, 8, col, 0, 7)
		px(holder, 10, 3, 12, 5, col, -35, 1)
		px(holder, 5, 3, 18, 2, col, 40, 1)
		px(holder, 5, 3, 18, 6, col, -40, 1)
	elseif kind == "shop" then                    -- shopping bag
		px(holder, 16, 13, 4, 8, col, 0, 2)
		px(holder, 3, 6, 7, 3, col, 0, 1)
		px(holder, 3, 6, 14, 3, col, 0, 1)
		px(holder, 8, 2, 8, 3, col, 0, 1)
	elseif kind == "copy" then                    -- two sheets
		px(holder, 11, 13, 3, 2, col, 0, 2)
		px(holder, 11, 13, 10, 9, col, 0, 2)
	end
	return holder
end

