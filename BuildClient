U.modelOverlapsScreenRect = function(model, minX, minY, maxX, maxY)
	local cf, size = model:GetBoundingBox()
	local half = size / 2
	local sxMin, syMin = math.huge, math.huge
	local sxMax, syMax = -math.huge, -math.huge
	local hasPointInFront = false

	for _, x in ipairs({ -1, 1 }) do
		for _, y in ipairs({ -1, 1 }) do
			for _, z in ipairs({ -1, 1 }) do
				local world = cf:PointToWorldSpace(Vector3.new(half.X * x, half.Y * y, half.Z * z))
				local screen = camera:WorldToViewportPoint(world)
				if screen.Z > 0 then
					hasPointInFront = true
					sxMin = math.min(sxMin, screen.X)
					syMin = math.min(syMin, screen.Y)
					sxMax = math.max(sxMax, screen.X)
					syMax = math.max(syMax, screen.Y)
				end
			end
		end
	end

	return hasPointInFront
		and sxMax >= minX and sxMin <= maxX
		and syMax >= minY and syMin <= maxY
end

local function gatherInBox(p1, p2)
	deselect()
	clearBoxSelection()
	if not itemsRoot then return end
	local minX, maxX = math.min(p1.X, p2.X), math.max(p1.X, p2.X)
	local minY, maxY = math.min(p1.Y, p2.Y), math.max(p1.Y, p2.Y)
	local activePlot = myPlotPart()

	for _, plotFolder in ipairs(itemsRoot:GetChildren()) do
		for _, model in ipairs(plotFolder:GetChildren()) do
			if model:IsA("Model") and plotOfModel(model) == activePlot
				and U.modelOverlapsScreenRect(model, minX, minY, maxX, maxY) then
				local h = Instance.new("Highlight")
				h.FillColor = C.ACCENT
				h.OutlineColor = C.ACCENT
				h.FillTransparency = 0.55
				h.Parent = model
				boxSelection[model] = h
			end
		end
	end

	local n = boxSelectionCount()
	U.boxCount.Text = n .. " selected"
	U.boxBar.Visible = n > 0
	if n == 0 then flash("Nothing inside that box") end
	refreshGroupHandles()
end

-- Send one item's new CFrame to the server (structures use resize)
local function sendItemTransform(model)
	local pivot = model:GetPivot()
	local rx, ry, rz = pivot:ToOrientation()
	if S.isStructure(model) then
		local part = model.PrimaryPart
		if not part then return true end
		local prx, pry, prz = part.CFrame:ToOrientation()
		return buildRemote:InvokeServer({
			action = "resize", target = model,
			sx = part.Size.X, sy = part.Size.Y, sz = part.Size.Z,
			x = part.Position.X, y = part.Position.Y, z = part.Position.Z,
			rot = pry, rx = prx, rz = prz,
		})
	end
	local scale = 1
	pcall(function() scale = model:GetScale() end)
	return buildRemote:InvokeServer({
		action = "transform", target = model,
		x = pivot.Position.X, y = pivot.Position.Y, z = pivot.Position.Z,
		rot = ry, rx = rx, rz = rz, scale = scale,
	})
end

local function boxCenter()
	local sum, n = Vector3.zero, 0
	for model in pairs(boxSelection) do
		sum += model:GetPivot().Position
		n += 1
	end
	return (n > 0) and (sum / n) or Vector3.zero
end

-- park the invisible proxy at the selection's centre and adorn handles
refreshGroupHandles = function()
	local n = boxSelectionCount()
	if n == 0 then
		groupHandles = false
		if U.moveHandles.Adornee == groupProxy then
			U.moveHandles.Adornee = nil
			U.arcHandles.Adornee = nil
		end
		return
	end
	-- fit the invisible proxy around the whole cluster: the handles then
	-- sit OUTSIDE the items, where you can actually grab them
	local minV, maxV
	for model in pairs(boxSelection) do
		local cf, size = model:GetBoundingBox()
		local half = size / 2
		local lo, hi = cf.Position - half, cf.Position + half
		minV = minV and Vector3.new(math.min(minV.X, lo.X), math.min(minV.Y, lo.Y), math.min(minV.Z, lo.Z)) or lo
		maxV = maxV and Vector3.new(math.max(maxV.X, hi.X), math.max(maxV.Y, hi.Y), math.max(maxV.Z, hi.Z)) or hi
	end
	local size = (maxV - minV)
	groupProxy.Size = Vector3.new(math.max(size.X, 2), math.max(size.Y, 2), math.max(size.Z, 2))
	groupProxy.CFrame = CFrame.new((minV + maxV) / 2)
	S.copyCellX = math.max(GRID, math.floor(size.X / GRID + 0.5) * GRID)
	S.copyCellZ = math.max(GRID, math.floor(size.Z / GRID + 0.5) * GRID)
	groupHandles = true
	U.selBox.Adornee = nil
	U.moveHandles.Adornee = groupProxy
	U.arcHandles.Axes = Axes.new(Enum.Axis.X, Enum.Axis.Y, Enum.Axis.Z)
	U.arcHandles.Adornee = groupProxy
	U.resizeHandles.Adornee = nil
end

local function commitGroup(startPivots)
	local failed = 0
	for model in pairs(boxSelection) do
		if model.Parent and not sendItemTransform(model) then
			failed += 1
			-- put rejected pieces back where they were so the client and
			-- server agree (otherwise they snap back on rejoin)
			if startPivots and startPivots[model] then
				model:PivotTo(startPivots[model])
			end
		end
	end
	if failed > 0 then
		flash(failed .. " piece(s) wouldn't fit on the plot - moved back")
	end
end

-- ⟲ rotate the whole selection about its centre
local function groupRotate(stepDegrees)
	if boxSelectionCount() == 0 then return end
	local center = boxCenter()
	local turn = CFrame.Angles(0, math.rad(stepDegrees or rotSnap()), 0)
	for model in pairs(boxSelection) do
		local pivot = model:GetPivot()
		local offset = pivot.Position - center
		local rotated = center + (turn * offset)
		model:PivotTo(CFrame.new(rotated) * (turn * pivot.Rotation))
	end

	if floatingCopies or groupDragActive then
		-- Keep rotated copies/dragged groups attached to the cursor after pressing R.
		refreshGroupHandles()
		groupStartPivots = {}
		for model in pairs(boxSelection) do
			groupStartPivots[model] = model:GetPivot()
		end
		S.groupProxyStart = groupProxy.CFrame
		local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
		if math.abs(unitRay.Direction.Y) > 1e-4 then
			local t = (groupDragY - unitRay.Origin.Y) / unitRay.Direction.Y
			if t > 0 then
				local grab = unitRay.Origin + unitRay.Direction * t
				groupDragOrigin = Vector3.new(grab.X, groupDragY, grab.Z)
			end
		end
	else
		commitGroup()
		refreshGroupHandles()
	end
end

