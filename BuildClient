S.dropFloatingCopies = function(continueStamp)
	if not (floatingCopies and groupStartPivots) or S.stampBusy then return end
	S.stampBusy = true
	floatingCopies = false
	local starts = groupStartPivots
	groupStartPivots = nil
	commitGroupRef(starts)
	refreshGroupHandlesRef()
	S.lastStampCenter = groupProxy.Position

	if continueStamp and S.stampMode and boxSelectionCount() > 0 then
		-- Clone the objects that were just placed, so repeated stamps preserve
		-- every rotation, scale, material and trim exactly.
		groupDupeRef()
	else
		flash("Placed!")
	end
	S.stampBusy = false
end

