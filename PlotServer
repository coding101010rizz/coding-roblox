-- The plot save is the single source of truth for currency. Previous
-- versions mixed TokenService, a zero-valued Tokens leaderstat, WalletServer,
-- and d.cash; whichever answered first could overwrite the others.
local function walletData(player)
	return playerData[player]
end

local function currencyStat(player, create)
	local ls = player:FindFirstChild("leaderstats")
	if not ls and create then
		ls = Instance.new("Folder")
		ls.Name = "leaderstats"
		ls.Parent = player
	end
	if not ls then return nil end
	local stat = ls:FindFirstChild(CURRENCY_PLURAL)
		or ls:FindFirstChild(CURRENCY_NAME)
		or ls:FindFirstChild("Sprigs")
		or ls:FindFirstChild("Tokens")
	if not stat and create then
		stat = Instance.new("IntValue")
		stat.Name = CURRENCY_PLURAL
		stat.Parent = ls
	end
	return stat
end

local function publishBalance(player)
	local d = walletData(player)
	local value = math.max(math.floor(tonumber(d and d.cash) or 0), 0)
	player:SetAttribute("Wallet", value)
	local stat = currencyStat(player, true)
	if stat and stat:IsA("ValueBase") then stat.Value = value end
	return value
end

local function awardCurrency(player, amount)
	amount = math.max(math.floor(tonumber(amount) or 0), 0)
	local d = walletData(player)
	if not d then return false end
	d.cash = math.max(math.floor(tonumber(d.cash) or 0) + amount, 0)
	markDirty(player)
	publishBalance(player)
	return true
end

local function spendCurrency(player, amount)
	amount = math.max(math.floor(tonumber(amount) or 0), 0)
	local d = walletData(player)
	if not d then return false end
	local have = math.max(math.floor(tonumber(d.cash) or 0), 0)
	if have < amount then return false end
	d.cash = have - amount
	markDirty(player)
	publishBalance(player)
	return true
end

local function tokenBalance(player)
	local d = walletData(player)
	return math.max(math.floor(tonumber(d and d.cash) or 0), 0)
end

local function priceOf(itemName)
	local t = findTemplate(itemName)
	local p = t and t:GetAttribute("Price")
	return (type(p) == "number" and p > 0) and math.floor(p) or 0
end

local slotAccessCache = {}
local function maxSlots(player)
	if PREMIUM_PASS_ID <= 0 then return BASE_SLOTS end
	if slotAccessCache[player.UserId] == nil then
		local owns = false
		pcall(function()
			owns = MarketplaceService:UserOwnsGamePassAsync(player.UserId, PREMIUM_PASS_ID)
		end)
		slotAccessCache[player.UserId] = owns
	end
	return slotAccessCache[player.UserId] and PREMIUM_SLOTS or BASE_SLOTS
end

