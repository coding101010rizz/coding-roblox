-- PERSISTENCE
--------------------------------------------------------------------
local function serializePlot(idx)
	local plot, folder = plots[idx], plotItemFolders[idx]
	if not (plot and folder) then return {} end
	local data = {}
	for _, model in ipairs(folder:GetChildren()) do
		if model:IsA("Model") then
			local pivot = model:GetPivot()
			local rel = plot.CFrame:ToObjectSpace(pivot)
			local rxO, ry, rzO = rel:ToOrientation()
			local kind = STRUCT_KIND[model.Name]
			if kind then
				local part = model.PrimaryPart
				if part then
					local srx, sry, srz = plot.CFrame:ToObjectSpace(part.CFrame):ToOrientation()
					local ca = model:GetAttribute("TrimColorA")
					local cb = model:GetAttribute("TrimColorB")
					table.insert(data, {
						k = kind,
						oid = model:GetAttribute("OpeningId"),
						tra = model:GetAttribute("TrimA"),
						trb = model:GetAttribute("TrimB"),
						tca = ca and { ca.R, ca.G, ca.B } or nil,
						tcb2 = cb and { cb.R, cb.G, cb.B } or nil,
						tma = model:GetAttribute("TrimMatA"),
						tmb = model:GetAttribute("TrimMatB"),
						tta = model:GetAttribute("TrimTransA"),
						ttb = model:GetAttribute("TrimTransB"),
						sx = part.Size.X, sy = part.Size.Y, sz = part.Size.Z,
						x = rel.Position.X, y = rel.Position.Y, z = rel.Position.Z, r = sry,
						rx = (math.abs(srx) > 0.01) and srx or nil,
						rz = (math.abs(srz) > 0.01) and srz or nil,
						m = part.Material.Name,
						c = { part.Color.R, part.Color.G, part.Color.B },
						t = part.Transparency,
						wd = part:IsA("WedgePart") and 1 or nil,
					})
				end
			else
				local scale = 1
				pcall(function() scale = model:GetScale() end)
				local entry = {
					n = model.Name,
					x = rel.Position.X, y = rel.Position.Y, z = rel.Position.Z, r = ry,
					rx = (math.abs(rxO) > 0.01) and rxO or nil,
					rz = (math.abs(rzO) > 0.01) and rzO or nil,
					s = scale,
				}
				-- persist the wall-opening record (healing works even
				-- after a rejoin/slot swap)
				local wSize = model:GetAttribute("WallSize")
				local wCF = model:GetAttribute("WallCF")
				if typeof(wSize) == "Vector3" and typeof(wCF) == "CFrame" then
					local wrel = plot.CFrame:ToObjectSpace(wCF)
					local wrx, wry, wrz = wrel:ToOrientation()
					local wc = model:GetAttribute("WallColor")
					entry.op = {
						wrel.Position.X, wrel.Position.Y, wrel.Position.Z, wry,
						wSize.X, wSize.Y, wSize.Z,
						tostring(model:GetAttribute("WallMat") or "SmoothPlastic"),
						wc and wc.R or 1, wc and wc.G or 1, wc and wc.B or 1,
						tonumber(model:GetAttribute("WallT")) or 0,
						tonumber(model:GetAttribute("OpeningId")) or 0,
						wrx, wrz,
					}
				end

				-- persist per-part paint jobs (index-ordered)
				if model:GetAttribute("Painted") then
					local pc = {}
					for _, part in ipairs(model:GetDescendants()) do
						if part:IsA("BasePart") then
							table.insert(pc, {
								part.Color.R, part.Color.G, part.Color.B,
								part.Material.Name, part.Transparency,
							})
						end
					end
					entry.pc = pc
				end
				table.insert(data, entry)
			end
		end
	end
	return data
end

local function spawnItem(idx, itemName, worldCFrame, scale)
	local template = findTemplate(itemName)
	if not template then return nil end
	if not ensurePrimaryPart(template) then return nil end
	local item = template:Clone()
	ensurePrimaryPart(item)
	if scale and scale ~= 1 then
		pcall(function() item:ScaleTo(math.clamp(scale, SCALE_MIN, SCALE_MAX)) end)
	end
	item:PivotTo(worldCFrame)
	for _, part in ipairs(item:GetDescendants()) do
		if part:IsA("BasePart") then
			part.Anchored = true
			part.CanQuery = true -- guarantees select/remove can target it
		end
	end
	item:SetAttribute("PlotIndex", idx)
	item.Parent = getItemFolder(idx)
	return item
end

local function rebuildEntry(idx, e)
	local plot = plots[idx]
	local rel = CFrame.new(e.x or 0, e.y or 0, e.z or 0)
		* CFrame.fromOrientation(e.rx or 0, e.r or 0, e.rz or 0)
	local worldCF = plot.CFrame:ToWorldSpace(rel)
	if e.k == "l" then
		-- rebuild a light exactly as it was
		local lc = (type(e.lc) == "table") and Color3.new(e.lc[1], e.lc[2], e.lc[3]) or nil
		spawnLight(idx, worldCF, lc, e.lb, e.lr, e.lk, e.ls)
	elseif e.k then
		local color = (type(e.c) == "table") and Color3.new(e.c[1] or 1, e.c[2] or 1, e.c[3] or 1) or nil
		local m = spawnStructure(idx, e.k, Vector3.new(e.sx or 1, e.sy or 1, e.sz or 1), worldCF, e.m, color, e.wd == 1)
		if m then
			if e.t then applyStructStyle(m, nil, nil, nil, nil, e.t) end
			if e.oid then m:SetAttribute("OpeningId", e.oid) end
			if e.tra and e.tra ~= "none" then
				local ca = e.tca and Color3.new(e.tca[1], e.tca[2], e.tca[3]) or nil
				applyTrim(m, e.tra, ca, 1, e.tma, e.tta)
			end
			if e.trb and e.trb ~= "none" then
				local cb = e.tcb2 and Color3.new(e.tcb2[1], e.tcb2[2], e.tcb2[3]) or nil
				applyTrim(m, e.trb, cb, -1, e.tmb, e.ttb)
			end
		end
	elseif type(e.n) == "string" then
		local furnRel = CFrame.new(e.x or 0, e.y or 0, e.z or 0)
			* CFrame.fromOrientation(e.rx or 0, e.r or 0, e.rz or 0)
		local item = spawnItem(idx, e.n, plot.CFrame:ToWorldSpace(furnRel), e.s)
		if item and type(e.op) == "table" and #e.op >= 12 then
			local wrel = CFrame.new(e.op[1], e.op[2], e.op[3])
				* CFrame.fromOrientation(e.op[14] or 0, e.op[4], e.op[15] or 0)
			item:SetAttribute("WallCF", plot.CFrame:ToWorldSpace(wrel))
			item:SetAttribute("WallSize", Vector3.new(e.op[5], e.op[6], e.op[7]))
			item:SetAttribute("WallMat", e.op[8])
			item:SetAttribute("WallColor", Color3.new(e.op[9], e.op[10], e.op[11]))
			item:SetAttribute("WallT", e.op[12])
			item:SetAttribute("OpeningId", e.op[13] or 0)
		end
		if item and type(e.pc) == "table" then
			item:SetAttribute("Painted", true)
			local i = 0
			for _, part in ipairs(item:GetDescendants()) do
				if part:IsA("BasePart") then
					i += 1
					local p = e.pc[i]
					if type(p) == "table" then
						part.Color = Color3.new(p[1] or 1, p[2] or 1, p[3] or 1)
						if p[4] and ALLOWED_MATERIALS[p[4]] then
							part.Material = Enum.Material[p[4]]
						end
						if tonumber(p[5]) then
							part.Transparency = math.clamp(p[5], 0, 0.9)
						end
					end
				end
			end
		end
	end
end

local function loadData(player)
	task.spawn(function()
		local data
		local ok, err = pcall(function()
			data = store:GetAsync("Player_" .. player.UserId)
		end)
		local d = playerData[player]
		if not d then return end
		if ok then
			d.loaded = true
			if data == nil then
				d.cash = STARTING_CASH -- first time here: give them a float
			end
		else
			warn("[PlotSave] " .. player.Name .. ": LOAD FAILED - " .. tostring(err)
				.. " (saving is disabled for this session to protect existing data)")
		end
		if ok and type(data) == "table" then
			d.cash = tonumber(data.cash) or 0
			d.inv = (type(data.inv) == "table") and data.inv or {}
			if type(data.slots) == "table" then
				d.slots = data.slots
				d.cur = math.clamp(math.floor(tonumber(data.cur) or 1), 1, PREMIUM_SLOTS)
			elseif type(data.placed) == "table" then
				d.slots = { [1] = data.placed } -- migrate old single-layout saves
				d.cur = 1
			end
		end
		pushInv(player)
		publishBalance(player)
		local total = 0
		for _, slot in pairs(d.slots) do total += #slot end
		print("[PlotSave] " .. player.Name .. ": loaded " .. total
			.. " saved objects across " .. #d.slots .. " slot(s), active slot " .. d.cur)
		local idx = playerPlot[player]
		if idx and not d.spawned then
			d.spawned = true
			for _, e in ipairs(d.slots[d.cur] or {}) do
				if #getItemFolder(idx):GetChildren() >= MAX_ITEMS then break end
				rebuildEntry(idx, e)
			end
		end
	end)
end

local function saveData(player, reason)
	local d = playerData[player]
	if not d then
		warn("[PlotSave] " .. player.Name .. ": no data table - nothing saved")
		return
	end
	if not d.loaded then
		warn("[PlotSave] " .. player.Name .. ": save SKIPPED because their data "
			.. "never loaded (DataStore unavailable? check Studio API access)")
		return
	end
	local idx = playerPlot[player]
	if idx then
		d.slots[d.cur] = serializePlot(idx)
	end
	local count = idx and #(d.slots[d.cur] or {}) or 0
	local ok, err = pcall(function()
		store:SetAsync("Player_" .. player.UserId, { inv = d.inv, cur = d.cur, slots = d.slots, cash = d.cash })
	end)
	if ok then
		print("[PlotSave] " .. player.Name .. ": saved " .. count .. " objects to slot "
			.. d.cur .. " (" .. (reason or "manual") .. ")")
		player:SetAttribute("LastPlotSave", os.clock()) -- client shows a toast
	else
		warn("[PlotSave] " .. player.Name .. ": SAVE FAILED - " .. tostring(err))
	end
end

