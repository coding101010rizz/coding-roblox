local function pushPartyStatus(idx)
	local owner = claims[idx]
	if not owner then return end
	local memberList = {}
	for m, role in pairs(members[idx] or {}) do
		table.insert(memberList, { name = m.Name, role = role })
	end
	local base = { cmd = "status", plotName = plots[idx].Name, members = memberList }
	for m in pairs(members[idx] or {}) do
		local p = table.clone(base); p.isOwner = false; p.myRole = members[idx][m]
		partyRemote:FireClient(m, p)
	end
	local p = table.clone(base); p.isOwner = true; p.myRole = "owner"
	partyRemote:FireClient(owner, p)
end

