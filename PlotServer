-- Accept plot pads that are Parts OR Models (uses the model's
-- PrimaryPart, else its biggest part) - grouping a pad with decorations
-- used to make it invisible to the whole system
local function padOf(child)
	if child:IsA("BasePart") then return child end
	if child:IsA("Model") then
		if child.PrimaryPart then return child.PrimaryPart end
		local biggest, best = nil, 0
		for _, p in ipairs(child:GetDescendants()) do
			if p:IsA("BasePart") then
				local v = p.Size.X * p.Size.Z
				if v > best then biggest, best = p, v end
			end
		end
		return biggest
	end
	return nil
end

local plots = {}
for _, child in ipairs(plotsFolder:GetChildren()) do
	local p = padOf(child)
	if p then
		-- Defensive hardening: an unanchored pad falls into the void at
		-- runtime and drags every teleport with it; a non-collidable pad
		-- drops players straight through. Force-fix and shout about it.
		if not p.Anchored then
			warn("[PlotSystem] Plot '" .. p.Name .. "' was NOT anchored - anchoring it. (This causes plots flying off / death loops!)")
			p.Anchored = true
		end
		if not p.CanCollide then
			warn("[PlotSystem] Plot '" .. p.Name .. "' had CanCollide OFF - enabling it. (Players were falling through!)")
			p.CanCollide = true
		end
		table.insert(plots, p)
	end
end
