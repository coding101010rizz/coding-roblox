claimRemote.OnServerInvoke = function(player, plotIndex)
	if plotIndex == "info" then return buildInfo() end
	if type(plotIndex) ~= "number" or not plots[plotIndex] then return false, "Invalid plot" end
	if playerPlot[player] then return false, "You already have a plot" end
	if claims[plotIndex] then return false, "Plot already taken" end

	claims[plotIndex] = player
	playerPlot[player] = plotIndex
	members[plotIndex] = {}
	plots[plotIndex]:SetAttribute("OwnerUserId", player.UserId)
	plots[plotIndex]:SetAttribute("AllowTeamBuild", true)
	plots[plotIndex]:SetAttribute("OwnerTeamName", player.Team and player.Team.Name or "")
	if BuildPermissions then
		pcall(BuildPermissions.InitializePlot, plots[plotIndex], player, true)
	end
	broadcast()
	teleportToPlot(player, plotIndex)
	pushPartyStatus(plotIndex)

	local d = playerData[player]
	if d and d.loaded and not d.spawned then
		d.spawned = true
		for _, e in ipairs(d.slots[d.cur] or {}) do
			rebuildEntry(plotIndex, e)
		end
	end
	return true, plots[plotIndex].Name
end

