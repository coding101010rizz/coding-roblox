-- LIGHTS: a small fitting plus a real light source. Colour, brightness
-- and range are all set by the player.
--------------------------------------------------------------------
local LIGHT_TYPES = { point = true, spot = true, glow = true }

local function spawnLight(idx, cf, colour, brightness, range, kind, size)
	kind = LIGHT_TYPES[kind] and kind or "point"
	colour = colour or Color3.fromRGB(255, 236, 200)
	brightness = math.clamp(tonumber(brightness) or 1.6, 0.2, 8)
	range = math.clamp(tonumber(range) or 18, 4, 60)
	size = math.clamp(tonumber(size) or 1, 0.4, 4)

	local model = Instance.new("Model")
	model.Name = "__Light"

	local bulb = Instance.new("Part")
	bulb.Name = "Structure"
	bulb.Shape = Enum.PartType.Ball
	bulb.Size = Vector3.one * size
	bulb.CFrame = cf
	bulb.Anchored = true
	bulb.CanCollide = false
	bulb.CanQuery = true
	bulb.Material = Enum.Material.Neon
	bulb.Color = colour
	bulb.Parent = model
	model.PrimaryPart = bulb

	if kind ~= "glow" then
		local src = Instance.new(kind == "spot" and "SpotLight" or "PointLight")
		src.Color = colour
		src.Brightness = brightness
		src.Range = range
		if kind == "spot" then
			src.Angle = 90
			src.Face = Enum.NormalId.Bottom
		end
		src.Parent = bulb
	end

	model:SetAttribute("LightKind", kind)
	model:SetAttribute("LightBright", brightness)
	model:SetAttribute("LightRange", range)
	model:SetAttribute("LightSize", size)
	model.Parent = getItemFolder(idx)
	return model
end

local function clearTrim(model)
	for _, child in ipairs(model:GetChildren()) do
		if child:IsA("BasePart") and child.Name == "Trim" then
			child:Destroy()
		end
	end
end

-- side: 1 or -1, which FACE of the wall gets the trim. Each face is
-- independent, so you can run baseboards inside and timber outside.
local function applyTrim(model, styleName, colour, side, materialName, transparency)
	if not (model and model.PrimaryPart) then return end
	side = (tonumber(side) or 1) >= 0 and 1 or -1
	local style = TRIM_STYLES[styleName or "none"]

	-- clear only the strips on THIS face; the other side keeps its own
	for _, child in ipairs(model:GetChildren()) do
		if child:IsA("BasePart") and child.Name == "Trim"
			and child:GetAttribute("Side") == side then
			child:Destroy()
		end
	end

	-- remember each face separately
	local key = (side == 1) and "TrimA" or "TrimB"
	local colourKey = (side == 1) and "TrimColorA" or "TrimColorB"
	local matKey = (side == 1) and "TrimMatA" or "TrimMatB"
	local transKey = (side == 1) and "TrimTransA" or "TrimTransB"
	model:SetAttribute(key, styleName)
	if colour then model:SetAttribute(colourKey, colour) end
	if materialName and ALLOWED_MATERIALS[materialName] then
		model:SetAttribute(matKey, materialName)
	end
	if transparency then model:SetAttribute(transKey, math.clamp(transparency, 0, 0.9)) end
	model:SetAttribute("Trim", styleName) -- legacy/simple lookups
	if not style then return end

	local wall = model.PrimaryPart
	local T, H, L = wall.Size.X, wall.Size.Y, wall.Size.Z
	local trimColour = colour or model:GetAttribute(colourKey)
		or Color3.fromRGB(248, 248, 244)
	local trimMat = materialName
	if not (trimMat and ALLOWED_MATERIALS[trimMat]) then
		trimMat = model:GetAttribute(matKey)
	end
	if not (trimMat and ALLOWED_MATERIALS[trimMat]) then
		trimMat = style.mat -- the style's own look (brick base = brick)
	end
	if not (trimMat and ALLOWED_MATERIALS[trimMat]) then trimMat = "SmoothPlastic" end
	local trimTrans = transparency or model:GetAttribute(transKey) or 0
	-- Door/window cuts create a top segment and, for windows, a bottom
	-- segment. These flags stop bottom trim from being rebuilt above a door
	-- and stop crown trim from appearing underneath a window.
	local allowBottom = model:GetAttribute("TrimAllowBottom") ~= false
	local allowTop = model:GetAttribute("TrimAllowTop") ~= false

	for _, band in ipairs(style) do -- numeric entries only; 'mat' is skipped
		-- Full-height skins always apply: a door/window segment must keep its
		-- face colour even where base/crown trim would be suppressed.
		if band.h ~= "full"
			and ((band.y == "bottom" and not allowBottom)
				or (band.y == "top" and not allowTop)) then
			continue
		end
		local bandH = (band.h == "full") and H or band.h
		local strip = Instance.new("Part")
		strip.Name = "Trim"
		strip.Anchored = true
		strip.CanCollide = false
		strip.CanQuery = true -- so the eyedropper can sample the trim itself
		strip.Material = Enum.Material[trimMat]
		strip.Color = trimColour
		strip.Transparency = math.clamp(trimTrans, 0, 0.9)
		strip:SetAttribute("Side", side)
		-- a thin board standing proud of ONE face only
		strip.Size = Vector3.new(band.out, bandH, L)

		local y
		if band.y == "bottom" then
			y = -H / 2 + bandH / 2 + band.drop
		else
			y = H / 2 - bandH / 2 - band.drop
		end
		strip.CFrame = wall.CFrame * CFrame.new(side * (T / 2 + band.out / 2), y, 0)
		strip.Parent = model
	end
end

-- rebuild both faces (used after a resize, or when copying a wall)
local function reapplyTrim(model)
	local a = model:GetAttribute("TrimA")
	local b = model:GetAttribute("TrimB")
	if a and a ~= "none" then
		applyTrim(model, a, model:GetAttribute("TrimColorA"), 1,
			model:GetAttribute("TrimMatA"), model:GetAttribute("TrimTransA"))
	end
	if b and b ~= "none" then
		applyTrim(model, b, model:GetAttribute("TrimColorB"), -1,
			model:GetAttribute("TrimMatB"), model:GetAttribute("TrimTransB"))
	end
end

local KIND_NAME = { w = "__Wall", f = "__Floor", r = "__Roof", l = "__Light" }

-- Floors/roofs may sit flush edge-to-edge but not overlap their own kind
local function overlapsSameKind(idx, kind, boxCF, boxSize)
	local wanted = KIND_NAME[kind]
	local includes = {}
	for _, m in ipairs(getItemFolder(idx):GetChildren()) do
		if m:IsA("Model") and m.Name == wanted then
			table.insert(includes, m)
		end
	end
	if #includes == 0 then return false end
	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Include
	params.FilterDescendantsInstances = includes
	local shrunk = Vector3.new(
		math.max(boxSize.X - 0.4, 0.1),
		math.max(boxSize.Y * 0.8, 0.1),
		math.max(boxSize.Z - 0.4, 0.1)
	)
	return #workspace:GetPartBoundsInBox(boxCF, shrunk, params) > 0
end

--------------------------------------------------------------------
-- WALL OPENINGS (shared by the door/window tools AND wall-fit items)
--------------------------------------------------------------------
local nextOpeningId = os.time() % 100000 -- unique across sessions

local function cutOpening(idx, wallModel, zc, openBottom, openTop, W)
	local part = wallModel.PrimaryPart
	if not part then return false end
	nextOpeningId += 1
	local openingId = nextOpeningId
	local T, H, L = part.Size.X, part.Size.Y, part.Size.Z
	if L < W + 0.5 then return false end
	zc = math.clamp(zc, -L/2 + W/2 + 0.1, L/2 - W/2 - 0.1)
	-- v9.3: if either side piece would be a sliver (<0.4 studs), nudge the
	-- opening inward so BOTH sides remain thick enough to spawn. This closes
	-- the "missing wall chunk next to a door" gap.
	local leftW  = (zc - W/2) + L/2
	local rightW = L/2 - (zc + W/2)
	if leftW < 0.4 then
		zc = zc + (0.4 - leftW)
	elseif rightW < 0.4 then
		zc = zc - (0.4 - rightW)
	end
	zc = math.clamp(zc, -L/2 + W/2 + 0.1, L/2 - W/2 - 0.1)
	openBottom = math.clamp(openBottom, 0, H - 0.5)
	openTop = math.clamp(openTop, openBottom + 0.5, H)

	local style = { part.Material.Name, part.Color, part.Transparency }
	local wallCF = part.CFrame
	local trimA = wallModel:GetAttribute("TrimA")
	local trimB = wallModel:GetAttribute("TrimB")
	local trimColourA = wallModel:GetAttribute("TrimColorA")
	local trimColourB = wallModel:GetAttribute("TrimColorB")
	local trimMatA = wallModel:GetAttribute("TrimMatA")
	local trimMatB = wallModel:GetAttribute("TrimMatB")
	local trimTransA = wallModel:GetAttribute("TrimTransA")
	local trimTransB = wallModel:GetAttribute("TrimTransB")

	local function segment(segH, localY, segL, localZ, allowBottom, allowTop)
		if segH < 0.15 or segL < 0.15 then return end
		local m = spawnStructure(idx, "w", Vector3.new(T, segH, segL),
			wallCF * CFrame.new(0, localY, localZ), style[1], style[2])
		if m then
			m:SetAttribute("OpeningId", openingId) -- so we can undo this cut
			m:SetAttribute("TrimAllowBottom", allowBottom ~= false)
			m:SetAttribute("TrimAllowTop", allowTop ~= false)
			if m.PrimaryPart then m.PrimaryPart.Transparency = style[3] end
			-- Carry each face independently, but only on the vertical region
			-- it occupied before the opening was cut.
			if trimA and trimA ~= "none" then
				applyTrim(m, trimA, trimColourA, 1, trimMatA, trimTransA)
			end
			if trimB and trimB ~= "none" then
				applyTrim(m, trimB, trimColourB, -1, trimMatB, trimTransB)
			end
		end
	end

	-- Full-height side pieces retain both base and crown trim.
	segment(H, 0, (zc - W/2) + L/2, (-L/2 + (zc - W/2)) / 2, true, true)
	segment(H, 0, L/2 - (zc + W/2), ((zc + W/2) + L/2) / 2, true, true)
	-- The piece over a door/window may retain crown trim, never base trim.
	segment(H - openTop, -H/2 + openTop + (H - openTop)/2, W, zc, false, true)
	if openBottom > 0.15 then
		-- The piece under a window may retain base trim, never crown trim.
		segment(openBottom, -H/2 + openBottom/2, W, zc, true, false)
	end

	local original = {
		size = part.Size,
		cf = part.CFrame,
		mat = part.Material.Name,
		color = part.Color,
		transparency = part.Transparency,
		trimA = trimA, trimB = trimB,
		trimColorA = trimColourA, trimColorB = trimColourB,
		trimMatA = trimMatA, trimMatB = trimMatB,
		trimTransA = trimTransA, trimTransB = trimTransB,
	}
	wallModel:Destroy()
	return true, openingId, original
end

-- Pick the BEST wall at a point: nearest to the click plane and long
-- enough for the item. Walls chopped up by earlier doors leave short
-- stubs, and grabbing one of those is what made placement "confused".
-- Put a wall back exactly as it was before a door/window cut it. Used by
-- BOTH removing and selling, so either route leaves a clean wall.
local function restoreWallFor(model, idx)
	local openingId = model:GetAttribute("OpeningId")
	local wallCF = model:GetAttribute("WallCF")
	local wallSize = model:GetAttribute("WallSize")
	if not (openingId and typeof(wallCF) == "CFrame" and typeof(wallSize) == "Vector3") then
		if model:GetAttribute("OpenSize") or model:GetAttribute("OpenCF") then
			warn("[Wall] '" .. model.Name .. "' was placed before the revert system "
				.. "existed - remove it, patch the gap once, then re-place it.")
		end
		return false
	end

	-- Leave it alone only if another DOOR/WINDOW still occupies this
	-- opening. The wall segments carry the same OpeningId, so they must be
	-- excluded here - counting them was what stopped the wall ever
	-- being restored.
	for _, other in ipairs(getItemFolder(idx):GetChildren()) do
		if other ~= model and other:IsA("Model")
			and not STRUCT_KIND[other.Name]
			and other:GetAttribute("OpeningId") == openingId then
			return false
		end
	end

	local removed = 0
	for _, seg in ipairs(getItemFolder(idx):GetChildren()) do
		if seg:IsA("Model") and seg.Name == "__Wall"
			and seg:GetAttribute("OpeningId") == openingId then
			seg:Destroy()
			removed += 1
		end
	end

	local restored = spawnStructure(idx, "w", wallSize, wallCF,
		model:GetAttribute("WallMat"), model:GetAttribute("WallColor"))
	if restored and restored.PrimaryPart then
		local t = tonumber(model:GetAttribute("WallT"))
		if t then restored.PrimaryPart.Transparency = math.clamp(t, 0, 0.9) end
		local ta = model:GetAttribute("WallTrimA")
		local tb = model:GetAttribute("WallTrimB")
		if ta and ta ~= "none" then
			applyTrim(restored, ta, model:GetAttribute("WallTrimColorA"), 1,
				model:GetAttribute("WallTrimMatA"), model:GetAttribute("WallTrimTransA"))
		end
		if tb and tb ~= "none" then
			applyTrim(restored, tb, model:GetAttribute("WallTrimColorB"), -1,
				model:GetAttribute("WallTrimMatB"), model:GetAttribute("WallTrimTransB"))
		end
	end
	print("[Wall] restored the original wall for " .. model.Name
		.. " (removed " .. removed .. " cut piece(s))")
	return true
end

local function wallAtPosition(idx, pos, minLength)
	local best, bestRel, bestDist = nil, nil, math.huge
	for _, m in ipairs(getItemFolder(idx):GetChildren()) do
		if m:IsA("Model") and m.Name == "__Wall" and m.PrimaryPart then
			local part = m.PrimaryPart
			local rel = part.CFrame:PointToObjectSpace(pos)
			local inside = math.abs(rel.X) <= part.Size.X/2 + 1.5
				and math.abs(rel.Y) <= part.Size.Y/2 + 0.5
				and math.abs(rel.Z) <= part.Size.Z/2
			local longEnough = (not minLength) or (part.Size.Z >= minLength + 0.5)
			if inside and longEnough then
				local dist = math.abs(rel.X)
				if dist < bestDist then
					best, bestRel, bestDist = m, rel, dist
				end
			end
		end
	end
	return best, bestRel
end

local function wallItemKind(template)
	local attr = template:GetAttribute("WallItem")
	if attr == "door" or attr == "window" then return attr end
	local parent = template.Parent
	if parent and parent:IsA("Folder") then
		local n = parent.Name:lower()
		if n == "doors" then return "door" end
		if n == "windows" then return "window" end
	end
	return nil
end

