local function applyStructStyle(model, mat, r, g, b, t)
	local part = model and model.PrimaryPart
	if not part then return end
	if mat and ALLOWED_MATERIALS[tostring(mat)] then
		part.Material = Enum.Material[tostring(mat)]
	end
	local rn, gn, bn = tonumber(r), tonumber(g), tonumber(b)
	if rn and gn and bn then
		part.Color = Color3.new(math.clamp(rn,0,1), math.clamp(gn,0,1), math.clamp(bn,0,1))
	end
	local tn = tonumber(t)
	if tn then
		part.Transparency = math.clamp(tn, 0, 0.9)
	end
end

local function spawnStructure(idx, kind, size, worldCFrame, materialName, color, wedge)
	local part = Instance.new(wedge and "WedgePart" or "Part")
	part.Anchored = true
	part.Size = size
	part.CFrame = worldCFrame
	part.Material = (materialName and ALLOWED_MATERIALS[materialName]) and Enum.Material[materialName] or Enum.Material.SmoothPlastic
	if color then
		part.Color = color
	else
		part.Color = (kind == "w") and WALL_COLOR or (kind == "r") and ROOF_COLOR or FLOOR_COLOR
	end
	part.Name = "Structure"

	local model = Instance.new("Model")
	model.Name = (kind == "w") and "__Wall" or (kind == "r") and "__Roof" or "__Floor"
	model:SetAttribute("StructureKind", kind)
	model:SetAttribute("PlotIndex", idx)
	part.Parent = model
	model.PrimaryPart = part
	model.Parent = getItemFolder(idx)
	return model
end

