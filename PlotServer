local function ensurePrimaryPart(model)
	if model.PrimaryPart then return true end
	local biggest, size = nil, 0
	for _, part in ipairs(model:GetDescendants()) do
		if part:IsA("BasePart") then
			local s = part.Size.X * part.Size.Y * part.Size.Z
			if s > size then biggest, size = part, s end
		end
	end
	model.PrimaryPart = biggest
	return biggest ~= nil
end

local function findTemplate(itemName)
	if not furnitureFolder then return nil end
	local direct = furnitureFolder:FindFirstChild(itemName)
	if direct and direct:IsA("Model") then return direct end
	local deep = furnitureFolder:FindFirstChild(itemName, true)
	if deep and deep:IsA("Model") then return deep end
	return nil
end

