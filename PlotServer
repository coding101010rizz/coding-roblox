-- BUILD ACTIONS
--------------------------------------------------------------------
local function resolvePlacedModel(target)
	if typeof(target) ~= "Instance" then return nil end
	local model = target
	while model and model.Parent and not (model.Parent.Parent == itemsRoot) do
		model = model.Parent
	end
	if model and model.Parent and model.Parent.Parent == itemsRoot then
		local idx = tonumber(model.Parent.Name:match("%d+"))
		return model, idx
	end
	return nil
end

local CHANGE_ACTIONS = {
	place = true, remove = true, wall = true, floor = true, roof = true,
	transform = true, resize = true, paint = true, clone = true,
	cutout = true, bulldoze = true, loadslot = true,
}

buildRemote.OnServerInvoke = function(player, payload)
	if type(payload) ~= "table" or type(payload.action) ~= "string" then return false, "Bad request" end
	if CHANGE_ACTIONS[payload.action] then
		task.defer(markDirty, player) -- schedule an autosave after this change
	end
	local d = playerData[player]
	local action = payload.action

	----------------------------------------------------------------
	if action == "place" then
		if type(payload.x) ~= "number" or type(payload.y) ~= "number"
			or type(payload.z) ~= "number" or type(payload.rot) ~= "number" then
			return false, "Bad position"
		end
		local pos = Vector3.new(payload.x, payload.y, payload.z)
		local idx = plotAtPosition(pos)
		if not idx then return false, "Outside any plot" end
		if not canBuild(player, idx) then return false, "Roommates only!" end
		if #getItemFolder(idx):GetChildren() >= MAX_ITEMS then return false, "Item limit reached" end

		local itemName = tostring(payload.item)
		local template = findTemplate(itemName)
		if not template then return false, "Unknown item" end

		------------------------------------------------------------
		-- WALL-FIT ITEMS (doors/windows): the wall carves itself to
		-- the model's size, then the model sits in the opening
		------------------------------------------------------------
		local wKind = wallItemKind(template)
		if wKind then
			local _, tSizePre = template:GetBoundingBox()
			local needed = math.max(tSizePre.X, tSizePre.Z) + 0.02
			local wallModel, relHit = wallAtPosition(idx, pos, needed)
			if not wallModel then
				return false, "No wall here big enough for that"
			end
			local wallPart = wallModel.PrimaryPart
			local wallCF, H = wallPart.CFrame, wallPart.Size.Y
			local _, tSize = template:GetBoundingBox()

			-- exact fit: the wall hugs the model instead of leaving gaps
			local W = math.min(math.max(tSize.X, tSize.Z) + 0.02, wallPart.Size.Z - 0.2)
			local itemH = tSize.Y
			local openBottom, openTop
			if wKind == "door" then
				openBottom = 0
				openTop = math.min(itemH + 0.02, H)
			else
				local clickBottom = (relHit.Y + H/2) - itemH/2
				openBottom = math.clamp(clickBottom, 0.2, math.max(H - itemH - 0.05, 0.2))
				openTop = math.min(openBottom + itemH + 0.02, H)
			end

			local zc = math.clamp(relHit.Z, -wallPart.Size.Z/2 + W/2 + 0.1, wallPart.Size.Z/2 - W/2 - 0.1)
			local wallBottomY = wallPart.Position.Y - H/2

			-- capture the wall's style + opening geometry BEFORE the cut,
			-- so removing the item later can HEAL the hole
			local healMat = wallPart.Material.Name
			local healColor = wallPart.Color
			local healT = wallPart.Transparency
			local healSize = Vector3.new(wallPart.Size.X, openTop - openBottom, W)
			local healCF = wallCF * CFrame.new(0, -H/2 + (openBottom + openTop)/2, zc)

			-- pay first (same rules as normal placement)
			if not d then return false, "Still loading..." end
			local ownedW = d.inv[itemName] or 0
			if ownedW > 0 then
				d.inv[itemName] = ownedW - 1
				if d.inv[itemName] <= 0 then d.inv[itemName] = nil end
			else
				local price = priceOf(itemName)
				if price > 0 then
					if not spendCurrency(player, price) then
						return false, "Not enough " .. CURRENCY_PLURAL .. "! (" .. price .. ")"
					end
				end
			end
			pushInv(player)

			local cutOk, openingId, original = cutOpening(idx, wallModel, zc, openBottom, openTop, W)
			if not cutOk then
				return false, "Wall too short for that item"
			end

			-- seat the item centered in the wall plane, facing the wall's way
			local itemPos = wallCF * CFrame.new(0, 0, zc)
			local tCF2, tSize2 = template:GetBoundingBox()
			local bottomDelta = template:GetPivot().Position.Y - (tCF2.Position.Y - tSize2.Y/2)
			local itemY = wallBottomY + openBottom + bottomDelta
			local yaw = math.rad(WALL_ITEM_YAW) + (payload.flip and math.pi or 0)
			local finalCF = CFrame.new(itemPos.Position.X, itemY, itemPos.Position.Z)
				* wallCF.Rotation * CFrame.Angles(0, yaw, 0)
			local item = spawnItem(idx, itemName, finalCF)
			if item then
				item:SetAttribute("PlacedBy", player.UserId)
				-- (returned below so the client can offer Undo)
				-- UNDO RECORD: removing this item deletes the segments the
				-- cut created and restores the ORIGINAL wall exactly, rather
				-- than patching the hole with an extra block
				item:SetAttribute("OpeningId", openingId)
				item:SetAttribute("WallCF", original.cf)
				item:SetAttribute("WallSize", original.size)
				item:SetAttribute("WallMat", original.mat)
				item:SetAttribute("WallColor", original.color)
				item:SetAttribute("WallT", original.transparency)
				if original.trimA then item:SetAttribute("WallTrimA", original.trimA) end
				if original.trimB then item:SetAttribute("WallTrimB", original.trimB) end
				if original.trimColorA then item:SetAttribute("WallTrimColorA", original.trimColorA) end
				if original.trimColorB then item:SetAttribute("WallTrimColorB", original.trimColorB) end
				if original.trimMatA then item:SetAttribute("WallTrimMatA", original.trimMatA) end
				if original.trimMatB then item:SetAttribute("WallTrimMatB", original.trimMatB) end
				if original.trimTransA then item:SetAttribute("WallTrimTransA", original.trimTransA) end
				if original.trimTransB then item:SetAttribute("WallTrimTransB", original.trimTransB) end
				return true, item
			end
			return false, "Placement failed"
		end

		local snapped = Vector3.new(math.round(pos.X/GRID)*GRID, pos.Y, math.round(pos.Z/GRID)*GRID)
		local rot = math.rad(math.round(math.deg(payload.rot) / 90) * 90)
		local placeCF = CFrame.new(snapped) * CFrame.Angles(0, rot, 0)

		local tCF, tSize = template:GetBoundingBox()
		local pivotToBox = template:GetPivot():ToObjectSpace(tCF)
		-- Overlap rule applies to FURNITURE ONLY: walls/floors/roofs are
		-- meant to touch things (and have things placed on them)
		local furnitureOnly = {}
		for _, m in ipairs(getItemFolder(idx):GetChildren()) do
			if m:IsA("Model") and not STRUCT_KIND[m.Name] then
				table.insert(furnitureOnly, m)
			end
		end
		if #furnitureOnly > 0 then
			local params = OverlapParams.new()
			params.FilterType = Enum.RaycastFilterType.Include
			params.FilterDescendantsInstances = furnitureOnly
			if #workspace:GetPartBoundsInBox(placeCF * pivotToBox, tSize * 0.85, params) > 0 then
				return false, "Too close to another item!"
			end
		end
		if not boxWithinPlot(idx, placeCF * pivotToBox, tSize) then
			return false, "Keep it inside your plot!"
		end

		------------------------------------------------------------
		-- STOCK RULE: every placement consumes one from your inventory.
		-- If you don't own one, we buy it on the spot (so nothing is ever
		-- free unless its Price is 0). This is what keeps the shop, your
		-- owned counts and the world in sync.
		------------------------------------------------------------
		if not d then return false, "Still loading..." end
		local owned = d.inv[itemName] or 0
		if owned > 0 then
			d.inv[itemName] = owned - 1
			if d.inv[itemName] <= 0 then d.inv[itemName] = nil end
		else
			local price = priceOf(itemName)
			if price > 0 then
				if not spendCurrency(player, price) then
					return false, "Not enough " .. CURRENCY_PLURAL .. "! (" .. price .. ")"
				end
			end
			-- bought and placed in one motion: nothing to add to the bag
		end
		pushInv(player)

		local item = spawnItem(idx, itemName, placeCF)
		if not item then
			-- stock is always consumed now, so always hand it back on failure
			if d then
				d.inv[itemName] = (d.inv[itemName] or 0) + 1
				pushInv(player)
			end
			return false, "Placement failed"
		end
		item:SetAttribute("PlacedBy", player.UserId)
		return true, item

		----------------------------------------------------------------
	elseif action == "remove" then
		local model, idx = resolvePlacedModel(payload.target)
		if not model then return false, "Not a placed item" end
		if not (idx and canBuild(player, idx)) then return false, "Roommates only!" end

		restoreWallFor(model, idx)

		if not STRUCT_KIND[model.Name] then
			local owner = claims[idx]
			local od = owner and playerData[owner]
			if od then
				od.inv[model.Name] = (od.inv[model.Name] or 0) + 1
				pushInv(owner)
			end
		end
		model:Destroy()
		return true

		----------------------------------------------------------------
	elseif action == "canbuild" then -- "am I allowed to build right here?"
		local character = player.Character
		local root = character and character:FindFirstChild("HumanoidRootPart")
		if not root then return false, "No character" end
		local idx = plotAtXZ(root.Position.X, root.Position.Z)
		if not idx then
			return false, "Go to your plot to build"
		end
		if not canBuild(player, idx) then
			local owner = claims[idx]
			if owner then
				return false, "This is " .. owner.Name .. "'s plot - ask to join their household"
			end
			return false, "This plot is unclaimed"
		end
		return true, plots[idx].Name

		----------------------------------------------------------------
	elseif action == "shop" then -- everything the shop needs in one call
		local list = {}
		if furnitureFolder then
			for _, child in ipairs(furnitureFolder:GetChildren()) do
				if child:IsA("Folder") then
					for _, m in ipairs(child:GetChildren()) do
						if m:IsA("Model") then
							table.insert(list, { name = m.Name, category = child.Name, price = priceOf(m.Name) })
						end
					end
				elseif child:IsA("Model") then
					table.insert(list, { name = child.Name, category = "Misc", price = priceOf(child.Name) })
				end
			end
		end
		return true, { items = list, balance = tokenBalance(player), owned = d and d.inv or {} }

		----------------------------------------------------------------
	elseif action == "buy" then -- purchase into the inventory
		if not d then return false, "Still loading..." end
		local itemName = tostring(payload.item)
		local template = findTemplate(itemName)
		if not template then return false, "That item doesn't exist" end
		local qty = math.clamp(math.floor(tonumber(payload.qty) or 1), 1, 10)
		local price = priceOf(itemName) * qty

		if price > 0 then
			-- The canonical saved wallet is used by the shop, WalletUI and admin panel.
			if not spendCurrency(player, price) then
				return false, "Not enough " .. CURRENCY_PLURAL .. " (need " .. price .. ")"
			end
		end
		d.inv[itemName] = (d.inv[itemName] or 0) + qty
		pushInv(player)
		return true, { balance = tokenBalance(player), owned = d.inv[itemName] }

		----------------------------------------------------------------
	elseif action == "homecatalog" then
		-- Reserved for Brookhaven-style whole-home imports. Keeping the API
		-- explicit now means templates can be added later without another UI rewrite.
		return true, { wip = true, templates = {} }

	elseif action == "importhome" then
		return false, "Home importing is still being built"

	elseif action == "sellplaced" then -- sell something already built
		local model, idx = resolvePlacedModel(payload.target)
		if not model then return false, "Not a placed item" end
		if not (idx and canBuild(player, idx)) then return false, "Roommates only!" end
		if STRUCT_KIND[model.Name] then
			return false, "Walls and roofs can't be sold - use Delete"
		end
		local refund = math.floor(priceOf(model.Name) * SELL_REFUND)
		restoreWallFor(model, idx) -- doors/windows put their wall back
		model:Destroy()
		if refund > 0 then
			awardCurrency(player, refund)
		end
		pushInv(player)
		return true, refund

		----------------------------------------------------------------
	elseif action == "sell" then
		local itemName = tostring(payload.item)
		if not (d and (d.inv[itemName] or 0) > 0) then return false, "Not in your inventory" end
		local refund = math.floor(priceOf(itemName) * SELL_REFUND)
		d.inv[itemName] -= 1
		if d.inv[itemName] <= 0 then d.inv[itemName] = nil end
		awardCurrency(player, refund)
		pushInv(player)
		return true, refund

		----------------------------------------------------------------
	elseif action == "wall" or action == "floor" or action == "roof" then
		local ax, az = tonumber(payload.ax), tonumber(payload.az)
		local bx, bz = tonumber(payload.bx), tonumber(payload.bz)
		local level = math.clamp(math.floor(tonumber(payload.level) or 0), MIN_LEVEL, MAX_LEVEL)
		if not (ax and az and bx and bz) then return false, "Bad points" end

		local idxA, idxB = plotAtXZ(ax, az), plotAtXZ(bx, bz)
		if not (idxA and idxA == idxB) then return false, "Stay on one plot" end
		if not canBuild(player, idxA) then return false, "Roommates only!" end
		if #getItemFolder(idxA):GetChildren() >= MAX_ITEMS then return false, "Item limit reached" end

		local baseY = levelBaseY(idxA, level)
		if action == "wall" then
			local a, b = Vector3.new(ax, 0, az), Vector3.new(bx, 0, bz)
			local length = (b - a).Magnitude
			if length < 1 then return false, "Too short" end
			if length > 120 then return false, "Too long" end
			-- v9.1 CORNER SEWING: extend both ends by half the wall thickness
			-- so two walls meeting at a corner close the outside notch instead
			-- of leaving an L-shaped gap. Endpoints were validated above.
			local axis = (b - a).Unit
			a -= axis * (WALL_THICKNESS / 2)
			b += axis * (WALL_THICKNESS / 2)
			length = (b - a).Magnitude
			-- A hair of height variance stops the coplanar TOP faces of the
			-- overlapping corner blocks from z-fighting. <=0.004 studs is
			-- invisible, and it persists through save/load like any size.
			local jitter = (#getItemFolder(idxA):GetChildren() % 5) * 0.001
			local mid = (a + b) / 2 + Vector3.new(0, baseY + (WALL_HEIGHT + jitter)/2, 0)
			local cf = CFrame.lookAt(mid, Vector3.new(b.X, mid.Y, b.Z))
			local m = spawnStructure(idxA, "w",
				Vector3.new(WALL_THICKNESS, WALL_HEIGHT + jitter, length), cf)
			applyStructStyle(m, payload.mat, payload.r, payload.g, payload.b, payload.t)
			return true
		else
			-- Server-side grid enforcement keeps mouse, touch, and imported requests
			-- aligned even if a client sends slightly imperfect coordinates.
			local snap = (action == "roof") and math.clamp(tonumber(payload.roofSnap) or 1, 0.25, 4) or GRID
			local plot = plots[idxA]
			local function snapXZ(x, z)
				local rel = plot.CFrame:PointToObjectSpace(Vector3.new(x, plot.Position.Y, z))
				local localPoint = Vector3.new(math.round(rel.X / snap) * snap, rel.Y, math.round(rel.Z / snap) * snap)
				local world = plot.CFrame:PointToWorldSpace(localPoint)
				return world.X, world.Z
			end
			ax, az = snapXZ(ax, az)
			bx, bz = snapXZ(bx, bz)

			local minX, maxX = math.min(ax, bx), math.max(ax, bx)
			local minZ, maxZ = math.min(az, bz), math.max(az, bz)
			local kind = (action == "roof") and "r" or "f"
			local overhang = (kind == "r") and math.clamp(tonumber(payload.overhang) or 0, 0, 4) or 0
			minX, maxX = minX - overhang, maxX + overhang
			minZ, maxZ = minZ - overhang, maxZ + overhang
			local sx, sz = maxX - minX, maxZ - minZ
			if sx < 1 or sz < 1 then return false, "Too small" end
			if sx > 128 or sz > 128 then return false, "Too big" end

			local thick = (kind == "r") and 0.6 or FLOOR_THICKNESS
			local verticalOffset = (kind == "r") and math.clamp(tonumber(payload.verticalOffset) or -0.08, -1, 1) or 0
			local baseTop = baseY + WALL_HEIGHT + verticalOffset
			local y = (kind == "r") and (baseTop + thick / 2) or (baseY + thick / 2 + 0.05)
			local midX, midZ = (minX + maxX) / 2, (minZ + maxZ) / 2
			local roofRotation = (math.round((tonumber(payload.roofRotation) or 0) / 90) * 90) % 180

			----------------------------------------------------------------
			-- SHAPED ROOFS: build at the origin exactly like the client preview,
			-- then rotate and move the complete result into the plot. This fixes
			-- the old mismatch where Turn/Edge/Grid changed the preview only.
			----------------------------------------------------------------
			local shape = tostring(payload.shape or "flat")
			if kind == "r" and shape ~= "flat" and RoofShapes then
				local buildX, buildZ = sx, sz
				if roofRotation == 90 then buildX, buildZ = sz, sx end
				local pitch = math.clamp(tonumber(payload.pitch) or 1, 0.4, 2.2)
				local rise = math.clamp(math.min(buildX, buildZ) * 0.35 * pitch, 1, 14)
				local pieces = RoofShapes.Build(shape, Vector3.zero, buildX, buildZ, rise)
				if #pieces == 0 then return false, "Unknown roof style" end

				local boundsCF = CFrame.new(midX, baseTop + rise / 2, midZ)
				local boundsSize = Vector3.new(sx, math.max(rise, 0.6), sz)
				if overlapsSameKind(idxA, "r", boundsCF, boundsSize) then
					return false, "Overlaps another roof!"
				end

				local roofWorld = CFrame.new(midX, baseTop, midZ) * CFrame.Angles(0, math.rad(roofRotation), 0)
				for _, piece in ipairs(pieces) do
					local m = spawnStructure(idxA, "r", piece.size, roofWorld * piece.cf, nil, nil, piece.wedge)
					applyStructStyle(m, payload.mat, payload.r, payload.g, payload.b, payload.t)
				end
				print("[Roof] built " .. shape .. " roof (" .. math.floor(sx) .. "x"
					.. math.floor(sz) .. ", grid " .. snap .. ", edge " .. overhang
					.. ", turn " .. roofRotation .. "°)")
				return true
			end

			local slabCF = CFrame.new(midX, y, midZ) * CFrame.Angles(0, math.rad(roofRotation), 0)
			local slabSize = Vector3.new(sx, thick, sz)
			if overlapsSameKind(idxA, kind, slabCF, slabSize) then
				return false, (kind == "r") and "Overlaps another roof!" or "Overlaps another floor!"
			end
			local m = spawnStructure(idxA, kind, slabSize, slabCF)
			applyStructStyle(m, payload.mat, payload.r, payload.g, payload.b, payload.t)
			return true
		end

		----------------------------------------------------------------
	elseif action == "cutout" then -- carve a door/window opening in a wall
		local model, idx = resolvePlacedModel(payload.target)
		if not (model and model.Name == "__Wall") then return false, "Click a wall" end
		if not (idx and canBuild(player, idx)) then return false, "Roommates only!" end
		local part = model.PrimaryPart
		if not part then return false, "Broken wall" end
		local hx = tonumber(payload.x)
		local hy = tonumber(payload.y)
		local hz = tonumber(payload.z)
		if not (hx and hy and hz) then return false, "Bad point" end

		local H = part.Size.Y
		local rel = part.CFrame:PointToObjectSpace(Vector3.new(hx, hy, hz))
		local isDoor = (payload.kind == "door")
		local openBottom = isDoor and 0 or math.min(3, H - 2)
		local openTop = math.min(7, H - 0.5)
		if openTop <= openBottom then return false, "Wall too low" end
		if not cutOpening(idx, model, rel.Z, openBottom, openTop, 4) then
			return false, "Wall too short for that"
		end
		return true

		----------------------------------------------------------------
	elseif action == "transform" then -- move/rotate/scale via select tool
		local model, idx = resolvePlacedModel(payload.target)
		if not model then return false, "Not a placed item" end
		if not (idx and canBuild(player, idx)) then return false, "Roommates only!" end
		if type(payload.x) ~= "number" or type(payload.y) ~= "number"
			or type(payload.z) ~= "number" or type(payload.rot) ~= "number" then
			return false, "Bad transform"
		end
		local pos = Vector3.new(payload.x, payload.y, payload.z)
		if plotAtPosition(pos) ~= idx then return false, "Keep it on the plot!" end

		-- 15-degree granularity so the client's 15/45/90 snap options all
		-- survive validation
		local rot = math.rad(math.round(math.deg(payload.rot) / 15) * 15)
		local rx = math.rad(math.round(math.deg(tonumber(payload.rx) or 0) / 15) * 15)
		local rz = math.rad(math.round(math.deg(tonumber(payload.rz) or 0) / 15) * 15)
		local prevPivot = model:GetPivot()
		model:PivotTo(CFrame.new(pos) * CFrame.fromOrientation(rx, rot, rz))

		-- Full bounding-box check: revert if any part of it left the plot
		local bcf, bsize = model:GetBoundingBox()
		if not boxWithinPlot(idx, bcf, bsize) then
			model:PivotTo(prevPivot)
			return false, "Keep it inside your plot!"
		end

		if not STRUCT_KIND[model.Name] and type(payload.scale) == "number" then
			pcall(function()
				model:ScaleTo(math.clamp(payload.scale, SCALE_MIN, SCALE_MAX))
			end)
		end
		return true

		----------------------------------------------------------------
	elseif action == "resize" then -- structures only
		local model, idx = resolvePlacedModel(payload.target)
		if not model then return false, "Not a placed item" end
		if not STRUCT_KIND[model.Name] then return false, "Only walls/floors resize" end
		if not (idx and canBuild(player, idx)) then return false, "Roommates only!" end
		local part = model.PrimaryPart
		if not part then return false, "Broken structure" end
		local sx = math.clamp(tonumber(payload.sx) or part.Size.X, 0.4, 120)
		local sy = math.clamp(tonumber(payload.sy) or part.Size.Y, 0.4, 24)
		local sz = math.clamp(tonumber(payload.sz) or part.Size.Z, 0.4, 120)
		local pos = Vector3.new(tonumber(payload.x) or part.Position.X,
			tonumber(payload.y) or part.Position.Y,
			tonumber(payload.z) or part.Position.Z)
		if plotAtXZ(pos.X, pos.Z) ~= idx then return false, "Keep it on the plot!" end
		local rot = tonumber(payload.rot) or 0
		local prx = math.rad(math.round(math.deg(tonumber(payload.rx) or 0) / 15) * 15)
		local prz = math.rad(math.round(math.deg(tonumber(payload.rz) or 0) / 15) * 15)
		local newCF = CFrame.new(pos) * CFrame.fromOrientation(prx, rot, prz)
		if not boxWithinPlot(idx, newCF, Vector3.new(sx, sy, sz)) then
			return false, "Keep it inside your plot!"
		end
		part.Size = Vector3.new(sx, sy, sz)
		part.CFrame = newCF
		reapplyTrim(model) -- refit both faces to the new length
		return true

		----------------------------------------------------------------
	elseif action == "slots" then -- list save slots
		if not d then return false, "Loading..." end
		local idx = playerPlot[player]
		local maxN = maxSlots(player)
		local counts = {}
		for i = 1, maxN do
			if idx and i == d.cur then
				counts[i] = #getItemFolder(idx):GetChildren()
			else
				counts[i] = d.slots[i] and #d.slots[i] or 0
			end
		end
		return true, { cur = d.cur, max = maxN, counts = counts }

		----------------------------------------------------------------
	elseif action == "loadslot" then -- switch to another saved layout
		if not d then return false, "Loading..." end
		if not d.loaded then return false, "Save data still loading" end
		local idx = playerPlot[player]
		if not idx then return false, "Claim a plot first" end
		if claims[idx] ~= player then return false, "Owner only" end
		local slot = math.floor(tonumber(payload.slot) or 0)
		if slot < 1 or slot > maxSlots(player) then return false, "Invalid slot" end
		if slot == d.cur then return false, "Already on that slot" end

		-- stash the current build, wipe the plot, rebuild the chosen slot
		d.slots[d.cur] = serializePlot(idx)
		getItemFolder(idx):ClearAllChildren()
		d.cur = slot
		for _, e in ipairs(d.slots[slot] or {}) do
			rebuildEntry(idx, e)
		end
		return true

		----------------------------------------------------------------
	elseif action == "roofpoly" then -- roof traced from points
		if not RoofShapes then return false, "Roof module missing" end
		local pts = payload.points
		if type(pts) ~= "table" or #pts < 3 or #pts > 16 then
			return false, "Trace 3-16 points"
		end

		-- every point must sit on ONE plot the player may build on
		local idx = nil
		local world = {}
		for _, p in ipairs(pts) do
			local px, pz = tonumber(p.x), tonumber(p.z)
			if not (px and pz) then return false, "Bad point" end
			local at = plotAtXZ(px, pz)
			if not at then return false, "Trace stays on your plot" end
			if idx and at ~= idx then return false, "Trace stays on one plot" end
			idx = at
			table.insert(world, Vector3.new(px, 0, pz))
		end
		if not canBuild(player, idx) then return false, "Roommates only!" end
		if #getItemFolder(idx):GetChildren() >= MAX_ITEMS then return false, "Item limit reached" end

		local level = math.clamp(math.floor(tonumber(payload.level) or 0), MIN_LEVEL, MAX_LEVEL)
		local roofSnap = math.clamp(tonumber(payload.roofSnap) or 1, 0.25, 4)
		local overhang = math.clamp(tonumber(payload.overhang) or 0, 0, 4)
		local verticalOffset = math.clamp(tonumber(payload.verticalOffset) or -0.08, -1, 1)
		local plot = plots[idx]
		for i, point in ipairs(world) do
			local rel = plot.CFrame:PointToObjectSpace(Vector3.new(point.X, plot.Position.Y, point.Z))
			local snapped = plot.CFrame:PointToWorldSpace(Vector3.new(
				math.round(rel.X / roofSnap) * roofSnap, rel.Y,
				math.round(rel.Z / roofSnap) * roofSnap))
			world[i] = Vector3.new(snapped.X, 0, snapped.Z)
		end
		if overhang > 0 then
			local center = Vector3.zero
			for _, point in ipairs(world) do center += point end
			center /= #world
			for i, point in ipairs(world) do
				local delta = point - center
				if delta.Magnitude > 0.001 then world[i] = point + delta.Unit * overhang end
			end
		end
		local baseTop = levelBaseY(idx, level) + WALL_HEIGHT + verticalOffset
		local pitch = math.clamp(tonumber(payload.pitch) or 1, 0.4, 2.2)

		-- size the rise from the outline's span
		local minX, maxX = math.huge, -math.huge
		local minZ, maxZ = math.huge, -math.huge
		for _, p in ipairs(world) do
			minX, maxX = math.min(minX, p.X), math.max(maxX, p.X)
			minZ, maxZ = math.min(minZ, p.Z), math.max(maxZ, p.Z)
		end
		local span = math.min(maxX - minX, maxZ - minZ)
		if span < 2 then return false, "Outline too small" end
		local rise = math.clamp(span * 0.35 * pitch, 1, 14)

		local pieces = RoofShapes.BuildPolygon(world, baseTop, rise, tostring(payload.shape or "hip"))
		if #pieces == 0 then return false, "Couldn't build that outline" end
		for _, piece in ipairs(pieces) do
			local m = spawnStructure(idx, "r", piece.size, piece.cf, nil, nil, piece.wedge)
			applyStructStyle(m, payload.mat, payload.r, payload.g, payload.b, payload.t)
		end
		print("[Roof] traced roof: " .. #world .. " points, " .. #pieces .. " pieces")
		return true

		----------------------------------------------------------------
	elseif action == "clone" then -- duplicate a placed item at an offset
		local model, idx = resolvePlacedModel(payload.target)
		if not model then return false, "Not a placed item" end
		if not (idx and canBuild(player, idx)) then return false, "Roommates only!" end
		if #getItemFolder(idx):GetChildren() >= MAX_ITEMS then return false, "Item limit reached" end

		-- The client can pass the exact spot it wants the copy (this is
		-- what makes duplicating a duplicate land on the DUPLICATE and
		-- not back at the original).
		local newCF
		if tonumber(payload.x) and tonumber(payload.y) and tonumber(payload.z) then
			local rx = tonumber(payload.rx) or 0
			local ry = tonumber(payload.rot) or 0
			local rz = tonumber(payload.rz) or 0
			newCF = CFrame.new(payload.x, payload.y, payload.z) * CFrame.fromOrientation(rx, ry, rz)
		else
			local dx = tonumber(payload.dx) or 0
			local dz = tonumber(payload.dz) or 0
			newCF = model:GetPivot() + Vector3.new(dx, 0, dz)
		end
		if plotAtPosition(newCF.Position) ~= idx then
			return false, "Copy would leave the plot"
		end

		local _, bsize = model:GetBoundingBox()
		if not boxWithinPlot(idx, newCF, bsize) then
			return false, "Copy would leave the plot"
		end

		if STRUCT_KIND[model.Name] then
			local part = model.PrimaryPart
			if not part then return false, "Broken structure" end
			local structCF = newCF
			if not (tonumber(payload.x) and tonumber(payload.y) and tonumber(payload.z)) then
				structCF = part.CFrame + (newCF.Position - model:GetPivot().Position)
			end
			-- v9.3: a copied WALL re-snaps its centre to the grid and keeps the
			-- same sewn length, so it stitches into corners exactly like a
			-- freshly-drawn wall instead of inheriting a stale offset.
			local copySize = part.Size
			if model.Name == "__Wall" then
				local pl = plots[idx]
				local rel = pl.CFrame:PointToObjectSpace(structCF.Position)
				local snapped = Vector3.new(
					math.round(rel.X / GRID) * GRID, rel.Y,
					math.round(rel.Z / GRID) * GRID)
				structCF = pl.CFrame:ToWorldSpace(CFrame.new(snapped)) * structCF.Rotation
			end
			local copy = spawnStructure(idx, STRUCT_KIND[model.Name], copySize,
				structCF, part.Material.Name, part.Color,
				part:IsA("WedgePart"))
			if copy and copy.PrimaryPart then
				copy.PrimaryPart.Transparency = part.Transparency
			end
			for _, key in ipairs({ "TrimA", "TrimB", "TrimColorA", "TrimColorB",
				"TrimMatA", "TrimMatB", "TrimTransA", "TrimTransB" }) do
				copy:SetAttribute(key, model:GetAttribute(key))
			end
			reapplyTrim(copy)
			return true, copy
		end

		local price = priceOf(model.Name)
		if price > 0 then
			if not spendCurrency(player, price) then
				return false, "Not enough " .. CURRENCY_PLURAL .. "! (" .. price .. ")"
			end
		end
		-- trust the client's reported scale when it sends one (the model
		-- may have been resized after it was placed), else read it back
		local scale = tonumber(payload.scale)
		if not scale then
			scale = 1
			pcall(function() scale = model:GetScale() end)
		end
		local copy = spawnItem(idx, model.Name, newCF, scale)
		if not copy then return false, "Copy failed" end
		copy:SetAttribute("PlacedBy", player.UserId)

		-- carry over any per-part paint job so the copy matches exactly
		-- (deliberately NOT copying OpenCF/OpenSize: a copy doesn't own
		-- the original's wall opening)
		if model:GetAttribute("Painted") then
			local srcParts, dstParts = {}, {}
			for _, p in ipairs(model:GetDescendants()) do
				if p:IsA("BasePart") then table.insert(srcParts, p) end
			end
			for _, p in ipairs(copy:GetDescendants()) do
				if p:IsA("BasePart") then table.insert(dstParts, p) end
			end
			for i, dst in ipairs(dstParts) do
				local src = srcParts[i]
				if src then
					dst.Color = src.Color
					dst.Material = src.Material
					dst.Transparency = src.Transparency
				end
			end
			copy:SetAttribute("Painted", true)
		end
		return true, copy

		----------------------------------------------------------------
	elseif action == "save" then -- force a save right now
		if not playerPlot[player] then return false, "You don't own a plot" end
		saveData(player, "manual save")
		local dd = playerData[player]
		if dd and not dd.loaded then return false, "Save unavailable (DataStore offline)" end
		return true, #(dd.slots[dd.cur] or {})

		----------------------------------------------------------------
	elseif action == "bulldoze" then -- clear the whole plot (owner only)
		local idx = playerPlot[player]
		if not idx then return false, "You don't own a plot" end
		if claims[idx] ~= player then return false, "Owner only" end
		local folder = getItemFolder(idx)
		local count = #folder:GetChildren()
		folder:ClearAllChildren()
		return true, count

		----------------------------------------------------------------
	elseif action == "light" then -- place a light fitting (costs currency)
		if type(payload.x) ~= "number" or type(payload.y) ~= "number"
			or type(payload.z) ~= "number" then
			return false, "Bad position"
		end
		local pos = Vector3.new(payload.x, payload.y, payload.z)
		local idx = plotAtPosition(pos)
		if not idx then return false, "Outside any plot" end
		if not canBuild(player, idx) then return false, "Roommates only!" end
		if #getItemFolder(idx):GetChildren() >= MAX_ITEMS then return false, "Item limit reached" end
		if not spendCurrency(player, LIGHT_COST) then
			return false, "Not enough " .. CURRENCY_PLURAL .. "! (" .. LIGHT_COST .. ")"
		end

		local r, g, b = tonumber(payload.r), tonumber(payload.g), tonumber(payload.b)
		local colour = (r and g and b)
			and Color3.new(math.clamp(r,0,1), math.clamp(g,0,1), math.clamp(b,0,1))
			or nil
		spawnLight(idx, CFrame.new(pos), colour, payload.bright, payload.range,
			tostring(payload.kind or "point"), payload.size)
		return true, LIGHT_COST

		----------------------------------------------------------------
	elseif action == "trim" then -- add/change/remove trim on a wall
		local model, idx = resolvePlacedModel(payload.target)
		if not model then return false, "Not a placed item" end
		if model.Name ~= "__Wall" then return false, "Trim goes on walls" end
		if not (idx and canBuild(player, idx)) then return false, "Roommates only!" end

		local style = tostring(payload.style or "none")
		if TRIM_STYLES[style] == nil then return false, "Unknown trim style" end
		local colour = nil
		local r, g, b = tonumber(payload.r), tonumber(payload.g), tonumber(payload.b)
		if r and g and b then
			colour = Color3.new(math.clamp(r,0,1), math.clamp(g,0,1), math.clamp(b,0,1))
		end
		-- which face did they click? the client sends the side it hit
		local side = (tonumber(payload.side) or 1) >= 0 and 1 or -1
		applyTrim(model, style, colour, side,
			tostring(payload.mat or ""), tonumber(payload.t))
		return true

		----------------------------------------------------------------
	elseif action == "paint" then -- structures AND furniture (per part)
		local model, idx = resolvePlacedModel(payload.target)
		if not model then return false, "Not a placed item" end
		if not (idx and canBuild(player, idx)) then return false, "Roommates only!" end

		if STRUCT_KIND[model.Name] then
			local clicked = payload.part
			if typeof(clicked) == "Instance" and clicked:IsA("BasePart")
				and clicked:IsDescendantOf(model) and clicked.Name == "Trim" then
				local side = (tonumber(clicked:GetAttribute("Side")) or 1) >= 0 and 1 or -1
				local styleKey = (side == 1) and "TrimA" or "TrimB"
				local currentStyle = model:GetAttribute(styleKey)
				if currentStyle and currentStyle ~= "none" then
					local r, g, b = tonumber(payload.r), tonumber(payload.g), tonumber(payload.b)
					local colour = (r and g and b)
						and Color3.new(math.clamp(r,0,1), math.clamp(g,0,1), math.clamp(b,0,1))
						or clicked.Color
					applyTrim(model, currentStyle, colour, side,
						tostring(payload.mat or clicked.Material.Name), tonumber(payload.t))
					return true
				end
			end
			-- Clicking the actual wall/floor/roof body changes only that body;
			-- trim remains an independently paintable child.
			applyStructStyle(model, payload.mat, payload.r, payload.g, payload.b, payload.t)
			return true
		end

		-- Furniture: paint the exact part that was clicked
		local part = payload.part
		if typeof(part) ~= "Instance" or not part:IsA("BasePart")
			or not part:IsDescendantOf(model) then
			part = model.PrimaryPart
		end
		if not part then return false, "Nothing to paint" end
		local mat = tostring(payload.mat)
		if ALLOWED_MATERIALS[mat] then part.Material = Enum.Material[mat] end
		local r, g, b = tonumber(payload.r), tonumber(payload.g), tonumber(payload.b)
		if r and g and b then
			part.Color = Color3.new(math.clamp(r,0,1), math.clamp(g,0,1), math.clamp(b,0,1))
		end
		local t = tonumber(payload.t)
		if t then part.Transparency = math.clamp(t, 0, 0.9) end
		model:SetAttribute("Painted", true) -- flags it for paint persistence
		return true
	end

	return false, "Unknown action"
end

--------------------------------------------------------------------
-- LIFECYCLE
--------------------------------------------------------------------
local function hookPlayer(player)
	playerData[player] = { inv = {}, slots = {}, cur = 1, cash = 0, spawned = false, loaded = false }
	loadData(player)
	player.CharacterAdded:Connect(function()
		task.wait(0.4)
		local idx = playerPlot[player]
		if idx then teleportToPlot(player, idx) end
	end)
end

Players.PlayerAdded:Connect(hookPlayer)
for _, p in Players:GetPlayers() do hookPlayer(p) end

Players.PlayerRemoving:Connect(function(player)
	pendingInvites[player] = nil
	lastTeleport[player] = nil
	saveData(player, "player leaving")
	local idx = playerPlot[player]
	if idx then
		claims[idx] = nil
		playerPlot[player] = nil
		members[idx] = nil
		if plotItemFolders[idx] then plotItemFolders[idx]:ClearAllChildren() end
		broadcast()
	else
		for i, set in pairs(members) do
			if set[player] then set[player] = nil pushPartyStatus(i) end
		end
	end
	playerData[player] = nil
	slotAccessCache[player.UserId] = nil
end)

-- AUTOSAVE loop (markDirty is defined earlier, near the top, so the
-- build handler can call it)
task.spawn(function()
	while true do
		task.wait(15)
		for player in pairs(dirty) do
			if player.Parent and playerPlot[player] then
				saveData(player, "autosave")
			end
			dirty[player] = nil
		end
	end
end)

-- belt and braces: a full pass every 2 minutes even without changes
task.spawn(function()
	while true do
		task.wait(120)
		for _, player in ipairs(Players:GetPlayers()) do
			if playerPlot[player] then saveData(player, "periodic") end
		end
	end
end)

game:BindToClose(function()
	for _, player in Players:GetPlayers() do saveData(player, "server closing") end
end)
