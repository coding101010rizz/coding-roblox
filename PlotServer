local function roleOf(player, idx)
	if claims[idx] == player then return "owner" end
	return members[idx] and members[idx][player] or nil
end

local function canBuild(player, idx)
	local r = roleOf(player, idx)
	if r == "owner" or r == "roommate" then return true end
	if BuildPermissions and plots[idx] then
		local ok = BuildPermissions.CanBuild(player, plots[idx])
		if ok then return true end
	end
	return false
end

local function plotContainsXZ(idx, x, z)
	local plot = plots[idx]
	local rel = plot.CFrame:PointToObjectSpace(Vector3.new(x, plot.Position.Y, z))
	return math.abs(rel.X) <= plot.Size.X/2 + BOUNDS_MARGIN
		and math.abs(rel.Z) <= plot.Size.Z/2 + BOUNDS_MARGIN
end

-- True only if ALL four XZ corners of an oriented box are on the plot
local function boxWithinPlot(idx, boxCF, boxSize)
	local hx, hz = boxSize.X / 2, boxSize.Z / 2
	local corners = {
		Vector3.new(hx, 0, hz), Vector3.new(hx, 0, -hz),
		Vector3.new(-hx, 0, hz), Vector3.new(-hx, 0, -hz),
	}
	for _, off in ipairs(corners) do
		local corner = (boxCF * CFrame.new(off)).Position
		if not plotContainsXZ(idx, corner.X, corner.Z) then
			return false
		end
	end
	return true
end

local function plotAtXZ(x, z)
	for i in ipairs(plots) do
		if plotContainsXZ(i, x, z) then return i end
	end
	return nil
end

local function plotAtPosition(pos)
	local idx = plotAtXZ(pos.X, pos.Z)
	if not idx then return nil end
	local topY = plots[idx].Position.Y + plots[idx].Size.Y / 2
	-- allowed vertical band: basement floor to above 3rd story
	if pos.Y < topY - WALL_HEIGHT - 6 or pos.Y > topY + WALL_HEIGHT * (MAX_LEVEL + 1) + 6 then
		return nil
	end
	return idx
end

local function plotTopY(idx)
	local plot = plots[idx]
	return plot.Position.Y + plot.Size.Y / 2
end

local function levelBaseY(idx, level)
	return plotTopY(idx) + level * WALL_HEIGHT
end

local function pushInv(player)
	local d = playerData[player]
	if d then
		invRemote:FireClient(player, d.inv, tokenBalance(player))
