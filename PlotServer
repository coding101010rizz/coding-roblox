partyRemote.OnServerEvent:Connect(function(player, payload)
	if type(payload) ~= "table" or type(payload.cmd) ~= "string" then return end
	local cmd = payload.cmd

	if cmd == "invite" then
		local idx = playerPlot[player]
		if not idx then return end
		local target = Players:FindFirstChild(tostring(payload.target))
		if not target or target == player or roleOf(target, idx) then return end
		pendingInvites[target] = pendingInvites[target] or {}
		pendingInvites[target][player] = idx
		partyRemote:FireClient(target, { cmd = "invite", from = player.Name, plotName = plots[idx].Name })

	elseif cmd == "respond" then
		local inviter = Players:FindFirstChild(tostring(payload.from))
		local invites = pendingInvites[player]
		if not (inviter and invites and invites[inviter]) then return end
		local idx = invites[inviter]
		invites[inviter] = nil
		if payload.accept == true and claims[idx] == inviter then
			members[idx][player] = "guest"

			-- Joining is instant, but the TELEPORT is rate-limited so
			-- invites can't be used to hop around the map at will.
			local now = os.clock()
			local last = lastTeleport[player]
			if last and (now - last) < TELEPORT_COOLDOWN then
				local wait = math.ceil(TELEPORT_COOLDOWN - (now - last))
				partyRemote:FireClient(player, {
					cmd = "notice",
					text = "Joined the household. You can teleport again in "
						.. wait .. "s - walk over for now.",
				})
			else
				lastTeleport[player] = now
				teleportToPlot(player, idx)
			end
			pushPartyStatus(idx)
		end

	elseif cmd == "setRole" then
		local idx = playerPlot[player]
		if not idx then return end
		local target = Players:FindFirstChild(tostring(payload.target))
		local role = payload.role
		if target and members[idx] and members[idx][target]
			and (role == "guest" or role == "roommate") then
			members[idx][target] = role
			pushPartyStatus(idx)
		end

	elseif cmd == "kick" then
		local idx = playerPlot[player]
		if not idx then return end
		local target = Players:FindFirstChild(tostring(payload.target))
		if target and members[idx] and members[idx][target] then
			members[idx][target] = nil
			partyRemote:FireClient(target, { cmd = "kicked", plotName = plots[idx].Name })
			pushPartyStatus(idx)
		end

	elseif cmd == "status" then
		local idx = playerPlot[player]
		if idx then
			pushPartyStatus(idx)
		else
			for i in pairs(claims) do
				if members[i] and members[i][player] then pushPartyStatus(i) break end
			end
		end
	end
end)

