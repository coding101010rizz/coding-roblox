-- lets other server scripts (e.g. the admin panel) top up the built-in
-- wallet without knowing how it's stored
local walletBridge = ServerScriptService:FindFirstChild("PlotWalletBridge")
if walletBridge and not walletBridge:IsA("BindableFunction") then walletBridge:Destroy(); walletBridge = nil end
if not walletBridge then
	walletBridge = Instance.new("BindableFunction")
	walletBridge.Name = "PlotWalletBridge"
	walletBridge.Parent = ServerScriptService
end
walletBridge.OnInvoke = function(player, request)
	if typeof(player) ~= "Instance" or not player:IsA("Player") then return false, "Bad player" end
	local d = playerData[player]
	if not d then return false, "Wallet is still loading" end

	-- Backward compatible: bridge:Invoke(player, 500) means add 500.
	local action, amount
	if type(request) == "table" then
		action = tostring(request.action or request.cmd or "get"):lower()
		amount = tonumber(request.amount) or 0
	else
		action = "add"
		amount = tonumber(request) or 0
	end
	amount = math.floor(amount)

	if action == "get" or action == "check" then
		return true, tokenBalance(player)
	elseif action == "add" or action == "give" or action == "award" then
		return awardCurrency(player, math.max(amount, 0)), tokenBalance(player)
	elseif action == "spend" or action == "take" then
		local ok = spendCurrency(player, math.max(amount, 0))
		return ok, tokenBalance(player)
	elseif action == "set" then
		d.cash = math.max(amount, 0)
		markDirty(player)
		publishBalance(player)
		return true, tokenBalance(player)
	elseif action == "topup" then
		local target = math.max(amount, 0)
		if tokenBalance(player) < target then d.cash = target end
		markDirty(player)
		publishBalance(player)
		return true, tokenBalance(player)
	end
	return false, "Unknown wallet action"
end

local permission = Instance.new("BindableFunction")
permission.Name = "PlotPermission"
permission.Parent = ServerScriptService
permission.OnInvoke = function(plotIndex, userId)
	plotIndex = tonumber(plotIndex)
	if not (plotIndex and plots[plotIndex]) then return nil end
	local owner = claims[plotIndex]
	if not owner then return nil end
	if owner.UserId == userId then return "owner" end
	for m, role in pairs(members[plotIndex] or {}) do
		if m.UserId == userId then return role end
	end
	return nil
end

