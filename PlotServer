-- Reuse one canonical copy of every remote. Running old PlotServer copies
-- used to create duplicate PlotBuild/PlotInv instances; clients could then
-- bind to an unhandled duplicate, leaving the GUI, shop and selection dead.
local function canonicalRemote(name, className)
	local chosen = nil
	for _, child in ipairs(ReplicatedStorage:GetChildren()) do
		if child.Name == name then
			if child.ClassName == className and not chosen then
				chosen = child
			else
				warn("[PlotSystem] Removing duplicate/invalid remote: " .. child:GetFullName())
				child:Destroy()
			end
		end
	end
	if not chosen then
		chosen = Instance.new(className)
		chosen.Name = name
		chosen.Parent = ReplicatedStorage
	end
	chosen:SetAttribute("BuildSystemCanonical", true)
	return chosen
end

